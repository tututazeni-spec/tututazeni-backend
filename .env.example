NODE_ENV=development

DATABASE_URL="postgresql://USER@localhost:5432/innova_dev"

# ─── Base de dados: pool e read-replicas (ver docs/db-architecture/) ───
# Tamanho máximo do pool de conexões do primary (escrita).
DB_POOL_MAX=50

# Read-replicas (leitura → réplica/slave). Desligadas por omissão: rollback = USE_REPLICAS=false.
USE_REPLICAS=false
DATABASE_REPLICA_URL="postgresql://USER@localhost:5433/innova_dev"
DB_REPLICA_POOL_MAX=10

# ─── Slow query logging (diagnóstico de performance) ───
# Define SLOW_QUERY_LOG para activar o registo de queries lentas.
# SLOW_QUERY_LOG=true
SLOW_QUERY_MS=500
SLOW_QUERY_LOG_FILE=load-tests/reports/slow-queries.log

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

# Fila / Redis (item 3a)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
QUEUE_ENABLED=true