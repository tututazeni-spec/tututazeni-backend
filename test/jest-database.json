{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "roots": ["<rootDir>/test/database"],
  "testEnvironment": "node",
  "testRegex": "test/database/.*\\.test\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 30000,
  "verbose": true,
  "forceExit": true,
  "detectOpenHandles": true,
  "maxWorkers": 1,
  "setupFiles": ["<rootDir>/test/database/jest-setup-env.ts"]
}
