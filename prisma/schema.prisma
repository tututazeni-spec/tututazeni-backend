// ══════════════════════════════════════════════════════════════════
// CORE — USER
// ══════════════════════════════════════════════════════════════════

model User {
  // ─── Identidade ───────────────────────────────────────────────
  id             Int     @id @default(autoincrement())
  fullName       String  @db.Text
  email          String  @unique
  password       String?
  employeeNumber String? @unique
  avatarUrl      String?

  // ─── Perfil Pessoal ───────────────────────────────────────────
  phone     String?
  birthDate DateTime?
  gender    String?
  country   String?
  city      String?

  // ─── Preferências ─────────────────────────────────────────────
  language String @default("pt")
  timezone String @default("Africa/Luanda")

  // ─── Status ───────────────────────────────────────────────────
  active        Boolean @default(true)
  accountStatus String  @default("PENDING")
  hrStatus      String  @default("ACTIVE")

  // ─── RH / Carreira ────────────────────────────────────────────
  hireDate DateTime?
  exitDate DateTime?

  // ─── Timestamps ───────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── FKs Organizacionais ──────────────────────────────────────
  roleId       Int?
  departmentId Int?
  positionId   Int?
  unitId       Int?
  managerId    Int?

  // ─── Relações Organizacionais ─────────────────────────────────
  role                    Role?                   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department              Department?             @relation("DeptMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  position                Position?               @relation("PositionUsers", fields: [positionId], references: [id])
  unit                    Unit?                   @relation(fields: [unitId], references: [id])
  manager                 User?                   @relation("Hierarchy", fields: [managerId], references: [id])
  subordinates            User[]                  @relation("Hierarchy")
  departmentHead          Department[]            @relation("DeptHead")
  departmentHeadHistory   DepartmentHeadHistory[]
  departmentTransferLogs  DepartmentTransferLog[]
  orgChanges              OrgChangeLog[]          @relation("OrgChangeUser")
  orgChangesPerformed     OrgChangeLog[]          @relation("OrgChangePerformer")
  developmentPlansManaged DevelopmentPlan[]       @relation("PDIManager")
  pdiEvidences            PdiEvidence[]
  pdiApprovals            PdiApproval[]
  reportApprovals         ReportApproval[]
  reportAccessLogs        ReportAccessLog[]
  notificationPreference  NotificationPreference?
  aiTutorMemory           AiTutorMemory?
  cohortParticipations    CohortParticipant[]
  eventParticipations     EventParticipant[]
  eventFeedbacks          EventFeedback[]
  attendanceRecords       AttendanceRecord[]  @relation("UserAttendanceRecords")
  createdVacancies InternalVacancy[] @relation("VacancyCreator")
  vacancyApplications InternalApplication[]
  
  // ─── Perfil & Gamificação ─────────────────────────────────────
  profile        Profile?
  points         UserPoints?
  badgeAwards    BadgeAward[]
  learningStreak LearningStreak?

  // ─── Competências ─────────────────────────────────────────────
  userCompetencies        UserCompetency[]
  competencyEvolutionLogs CompetencyEvolutionLog[]
  endorsementsGiven       CompetencyEndorsement[]  @relation("EndorsementGiven")
  endorsementsReceived    CompetencyEndorsement[]  @relation("EndorsementReceived")
  competencyMaps          CompetencyMap[]          @relation("UserCompetencyMaps")
  assessedCompetencyMaps  CompetencyMap[]          @relation("AssessedCompetencyMaps")

  // ─── Aprendizagem ─────────────────────────────────────────────
  enrollments             Enrollment[]
  certificates            Certificate[]
  lessonProgress          LessonProgress[]
  quizAttempts            QuizAttempt[]
  assessmentAttempts      AssessmentAttempt[]
  learningPathEnrollments LearningPathEnrollment[]
  courseFeedbacks         CourseFeedback[]

  // ─── Micro-Learning ───────────────────────────────────────────
  microLearningProgress     MicroLearningProgress[]
  microLearningInteractions MicroLearningInteraction[]
  microQuizAttempts         MicroQuizAttempt[]
  microLearningPlaylists    MicroLearningPlaylist[]
  microLearningsAuthored    MicroLearning[]

  // ─── Treinamentos ─────────────────────────────────────────────
  instructedTrainings  Training[]
  trainingParticipants TrainingParticipant[]
  trainingRatings      TrainingRating[]

  // ─── Onboarding ───────────────────────────────────────────────
  onboardingAsUser    OnboardingPlan[] @relation("OnboardingPlanUser")
  onboardingAsBuddy   OnboardingPlan[]         @relation("OnboardingBuddy")
  onboardingAsManager OnboardingPlan[]         @relation("OnboardingManager")
  onboardingAsHR      OnboardingPlan[]         @relation("OnboardingHR")
  taskApprovals       OnboardingTaskInstance[] @relation("TaskApprover")
  documentsUploaded   OnboardingDocument[]     @relation("DocUploader")
  documentsValidated  OnboardingDocument[]     @relation("DocValidator")

  // ─── Conhecimento ─────────────────────────────────────────────
  articles                KnowledgeArticle[]
  knowledgeInteractions   KnowledgeInteraction[]
  articleComments         ArticleComment[]
  articleRatings          ArticleRating[]
  articleVersions         ArticleVersion[]
  articleAcknowledgements ArticleAcknowledgement[]
  articleQuestionsAsked   ArticleQuestion[]        @relation("QuestionAsker")

  // ─── Performance ──────────────────────────────────────────────
  performanceReviews             PerformanceReview[]     @relation("ReviewedUser")
  performanceReviewsGiven        PerformanceReview[]     @relation("ReviewerUser")
  performanceGoals               PerformanceGoal[]
  continuousFeedbackGiven        ContinuousFeedback[]    @relation("FeedbackGiver")
  continuousFeedbackReceived     ContinuousFeedback[]    @relation("FeedbackReceived")
  nineBoxPlacements              NineBoxPlacement[]      @relation("NineBoxUser")
  nineBoxUpdated                 NineBoxPlacement[]      @relation("NineBoxUpdater")
  calibratedReviews              CalibrationLog[]
  performanceDisputes            PerformanceDispute[]
  performanceEvaluationsGiven    PerformanceEvaluation[] @relation("EvaluatorRelation")
  performanceEvaluationsReceived PerformanceEvaluation[] @relation("EvaluatedRelation")
  evaluationRequestsGiven        EvaluationRequest[]     @relation("RequestEvaluator")
  evaluationRequestsReceived     EvaluationRequest[]     @relation("RequestEvaluated")

  // ─── Liderança ────────────────────────────────────────────────
  leadershipParticipations LeadershipParticipant[]
  oneOnOnesAsManager       OneOnOne[]              @relation("OneOnOneManager")
  oneOnOnesAsSubordinate   OneOnOne[]              @relation("OneOnOneSubordinate")
  leadershipFeedbacks      LeadershipFeedback360[] @relation("LeaderFeedback")
  mentoringAsMentor        Mentoring[]             @relation("MentoringMentor")
  mentoringAsMentee        Mentoring[]             @relation("MentoringMentee")
  kudosSent                Kudos[]                 @relation("KudosSender")
  kudosReceived            Kudos[]                 @relation("KudosReceiver")
  leadershipScore          LeadershipScore?

  // ─── Carreira ─────────────────────────────────────────────────
  careers             UserCareer[]
  userCareerPlans     UserCareerPlan[]   @relation("UserCareerPlans")
  mentoredCareerPlans UserCareerPlan[]   @relation("CareerMentor")
  promotionRequests   PromotionRequest[] @relation("PromotionRequester")
  promotionReviews    PromotionRequest[] @relation("PromotionReviewer")
  successionPlans     SuccessionPlan[]
  talentPool          TalentPool?
  talentPoolMentor    TalentPool[]    @relation("TalentPoolMentor")
  developmentPlans    DevelopmentPlan[]

  // ─── Processos ────────────────────────────────────────────────
  processStandardsOwned ProcessStandard[]
  processStepsOwned     ProcessStep[]
  initiatedInstances    ProcessInstance[]    @relation("InstanceInitiator")
  targetInstances       ProcessInstance[]    @relation("InstanceTarget")
  completedSteps        StepProgress[]
  processApprovalLogs   ProcessApprovalLog[]
  processAuditLogs      ProcessAuditLog[]

  // ─── Eventos & Presença ───────────────────────────────────────
  events             Event[]
  liveAttendances    LiveAttendance[]
  liveMessages       LiveChatMessage[]
  postClassResponses PostClassResponse[]
  userAttendances    UserAttendance[]

  // ─── Documentos & Relatórios ──────────────────────────────────
  companyDocuments  CompanyDocument[]
  documentDownloads DocumentDownload[]
  reportLogs        ReportLog[]
  executiveReports  ExecutiveReport[]
  historyRecords    HistoryRecord[]

  // ─── RH Operacional ───────────────────────────────────────────
  payslips                 Payslip[]
  payslipAccessLogs        PayslipAccessLog[]
  workDeclarations         WorkDeclaration[]
  surveyResponses          SurveyResponse[]
  leaveRequests            LeaveRequest[]
  leaveApprovals           LeaveApproval[]
  leaveBalances            LeaveBalance[]
  overtimeRecords          OvertimeRecord[]
  userSchedule             UserSchedule?
  attendanceJustifications AttendanceJustification[]
  attendanceAdjustments    AttendanceAdjustment[]
  payrollRunsCreated       PayrollRun[]              @relation("PayrollRunCreator")
  employeeCompensations    EmployeeCompensation[]

  // ─── Notificações & Auditoria ─────────────────────────────────
  notificationLogs NotificationLog[]
  auditLogs        AuditLog[]
  userAuditLogs    UserAuditLog[]    @relation("AuditTarget")
  auditPerformed   UserAuditLog[]    @relation("AuditPerformer")

  // ─── Mobile ───────────────────────────────────────────────────
  mobileSessions MobileSession[]
  mobileSyncLogs MobileSyncLog[]

  // ─── IA & Sessões ─────────────────────────────────────────────
  aiSessions     AiTutorSession[]
  avatarSessions AvatarSession[]

  // ─── Instrutor ────────────────────────────────────────────────
  instructorProfile InstructorProfile?
  instructorReviews InstructorReview[]

  // ─── Q&A ──────────────────────────────────────────────────────
  questions Questions[]
  answers   Answers[]

  // ─── Documentos (Repositório) ─────────────────────────────────
  createdDocuments      Document[]      @relation("DocCreator")
  ownedDocuments        Document[]      @relation("DocOwner")
  uploadedDocVersions   DocVersion[]
  docPermissions        DocPermission[]
  grantedDocPermissions DocPermission[] @relation("PermissionGrantor")
  docShareLinks         DocShareLink[]
  docDownloads          DocDownload[]
  docAuditLogs          DocAuditLog[]

  // ─── Declarações ──────────────────────────────────────────────
  declarationTemplates DeclarationTemplate[]
  declarationRequests  DeclarationRequest[]
  declarationApprovals DeclarationApproval[]
  workDeclForms        WorkDeclForm[]
  workDeclSubmissions  WorkDeclSubmission[]
  workDeclReviews      WorkDeclReview[]

  // ─── Declarations ──────────────────────────────────────────
declarationsRequested       Declaration[]            @relation("DeclarationRequestedBy")
declarationsAssigned        Declaration[]            @relation("DeclarationAssignedTo")
declarationsAsEmployee      Declaration[]            @relation("DeclarationEmployee")
declarationSignatures       DeclarationSignature[]
declarationAuditLogs        DeclarationAuditLog[]
declarationAttachments      DeclarationAttachment[]
declarationTemplatesUpdated DeclarationTemplate[]    @relation("TemplateUpdatedBy")

  // ─── Skills ───────────────────────────────────────────────────
  legacySkills         LegacyEmployeeSkill[]
  assessedLegacySkills LegacyEmployeeSkill[] @relation("SkillAssessor")
  workDeclAnswers      WorkDeclAnswer[]

  // ─── CRM Beneficiários ────────────────────────────────────────
  createdBeneficiaries         Beneficiary[]            @relation("BeneficiaryCreator")
  assignedBeneficiaries        Beneficiary[]            @relation("BeneficiaryOwner")
  beneficiaryInteractions      BeneficiaryInteraction[] @relation("InteractionUser")
  uploadedBeneficiaryDocuments BeneficiaryDocument[]    @relation("DocumentUploader")

  // ─── CRM Parceiros ────────────────────────────────────────────
  createdPartners          Partner[]            @relation("PartnerCreator")
  assignedPartners         Partner[]            @relation("PartnerOwner")
  partnerInteractions      PartnerInteraction[] @relation("PartnerInteractionUser")
  createdPartnerMilestones PartnerMilestone[]   @relation("MilestoneCreator")

  // ─── CRM Financiadores ────────────────────────────────────────
  createdFunders          Funder[]            @relation("FunderCreator")
  assignedFunders         Funder[]            @relation("FunderOwner")
  createdGrantDisbursements GrantDisbursement[] @relation("DisbursementCreator")
  funderInteractions      FunderInteraction[] @relation("FunderInteractionUser")
  createdFunderReports    FunderReport[]      @relation("ReportCreator")
  @@index([accountStatus])
  @@index([departmentId])
  @@index([managerId])
  @@index([active])
  @@index([roleId])
  @@index([unitId])
}

model Profile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  bio         String?  @db.Text
  interests   String[]
  careerGoals String?
  linkedinUrl String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  performedById Int
  action        String
  meta          String?
  createdAt     DateTime @default(now())
  user          User     @relation("AuditTarget", fields: [userId], references: [id])
  performedBy   User     @relation("AuditPerformer", fields: [performedById], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Questions {
  id        Int       @id @default(autoincrement())
  title     String    @db.Text
  body      String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  answers   Answers[]
}

model Answers {
  id         Int       @id @default(autoincrement())
  body       String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     Int
  questionId Int
  user       User      @relation(fields: [userId], references: [id])
  question   Questions @relation(fields: [questionId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
// ROLES & PERMISSÕES
// ══════════════════════════════════════════════════════════════════

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?          @db.Text
  users           User[]
  permissions     Permission[]
  code            String? @unique
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  action          String
  subject         String
  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@index([action])
  @@index([subject])
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════
// ORGANIZAÇÃO
// ══════════════════════════════════════════════════════════════════

model Department {
  id                  Int                     @id @default(autoincrement())
  code                String                  @unique
  name                String
  description         String?
  active              Boolean                 @default(true)
  status              String                  @default("ACTIVE")
  color               String?
  icon                String?
  costCenter          String?
  annualBudget        Float?
  trainingBudget      Int?
  parentId            Int?
  headId              Int?
  unitId              Int?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  parent              Department?             @relation("DeptHierarchy", fields: [parentId], references: [id])
  children            Department[]            @relation("DeptHierarchy")
  head                User?                   @relation("DeptHead", fields: [headId], references: [id])
  unit                Unit?                   @relation(fields: [unitId], references: [id])
  users               User[]                  @relation("DeptMembers")
  headHistory         DepartmentHeadHistory[]
  transfersIn         DepartmentTransferLog[] @relation("TransferTo")
  transfersOut        DepartmentTransferLog[] @relation("TransferFrom")
  dashboardSnapshots  DashboardSnapshot[]
  companyDocuments    CompanyDocument[]
  executiveReports    ExecutiveReport[]
  processStandards    ProcessStandard[]
  onboardingTemplates OnboardingTemplate[]
  orgChangesFrom      OrgChangeLog[]          @relation("OrgChangeFrom")
  orgChangesTo        OrgChangeLog[]          @relation("OrgChangeTo")
  courses             Course[]
  internalVacancies   InternalVacancy[]
  careerPaths CareerPath[]
  @@index([active])
  @@index([parentId])
}

model DepartmentHeadHistory {
  id           Int        @id @default(autoincrement())
  departmentId Int
  headId       Int
  startedAt    DateTime   @default(now())
  endedAt      DateTime?
  department   Department @relation(fields: [departmentId], references: [id])
  head         User       @relation(fields: [headId], references: [id])
}

model DepartmentTransferLog {
  id               Int         @id @default(autoincrement())
  userId           Int
  fromDepartmentId Int?
  toDepartmentId   Int
  reason           String?
  transferredAt    DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id])
  fromDepartment   Department? @relation("TransferFrom", fields: [fromDepartmentId], references: [id])
  toDepartment     Department  @relation("TransferTo", fields: [toDepartmentId], references: [id])

  @@index([userId])
  @@index([toDepartmentId])
}

model Unit {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  type               String              @default("BRANCH")
  province           String?
  address            String?
  city               String?
  country            String?
  timezone           String?
  phone              String?
  email              String?
  users              User[]
  departments        Department[]
  operationalMetrics OperationalMetric[]
}

model Position {
  id                  Int                  @id @default(autoincrement())
  name                String
  code                String?
  description         String?
  level               String?
  departmentId        Int?
  salaryMin           Float?
  salaryMax           Float?
  headcountPlanned    Int?                 @default(1)
  users               User[]               @relation("PositionUsers")
  successionPlans     SuccessionPlan[]
  competencies        PositionCompetency[]
  onboardingTemplates OnboardingTemplate[]
  orgChangesFrom      OrgChangeLog[]       @relation("OrgChangePosFrom")
  careerPathSteps     CareerPathStep[]
  internalVacancies   InternalVacancy[]
  orgChangesTo        OrgChangeLog[]       @relation("OrgChangePosTto")
  criticalPositions   CriticalPosition[]
}

model OrgChangeLog {
  id               Int         @id @default(autoincrement())
  userId           Int
  changeType       String
  fromDepartmentId Int?
  toDepartmentId   Int?
  fromPositionId   Int?
  toPositionId     Int?
  fromManagerId    Int?
  toManagerId      Int?
  effectiveDate    DateTime
  reason           String?
  notes            String?
  performedById    Int
  createdAt        DateTime    @default(now())
  user             User        @relation("OrgChangeUser", fields: [userId], references: [id])
  performedBy      User        @relation("OrgChangePerformer", fields: [performedById], references: [id])
  fromDepartment   Department? @relation("OrgChangeFrom", fields: [fromDepartmentId], references: [id])
  toDepartment     Department? @relation("OrgChangeTo", fields: [toDepartmentId], references: [id])
  fromPosition     Position?   @relation("OrgChangePosFrom", fields: [fromPositionId], references: [id])
  toPosition       Position?   @relation("OrgChangePosTto", fields: [toPositionId], references: [id])

  @@index([userId])
  @@index([changeType])
  @@index([effectiveDate])
}

// ══════════════════════════════════════════════════════════════════
// CARREIRA
// ══════════════════════════════════════════════════════════════════

model UserCareerPlan {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          User               @relation("UserCareerPlans", fields: [userId], references: [id])
  title         String
  description   String?
  status        CareerPlanStatus   @default(DRAFT)
  currentRoleId Int?
  currentRole   CareerRole?        @relation("CurrentRole", fields: [currentRoleId], references: [id])
  targetRoleId  Int?
  targetRole    CareerRole?        @relation("TargetRole", fields: [targetRoleId], references: [id])
  careerPathId  Int?
  careerPath    CareerPath?        @relation(fields: [careerPathId], references: [id])
  mentorId      Int?
  mentor        User?              @relation("CareerMentor", fields: [mentorId], references: [id])
  targetDate    DateTime?
  activatedAt   DateTime?
  goals         CareerGoal[]
  promotions    PromotionRequest[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId, status])
}

model CareerRole {
  id                Int                    @id @default(autoincrement())
  name              String
  description       String?
  department        String
  seniority         String?
  level             Int                    @default(1)
  salaryMin         Float?
  salaryMax         Float?
  parentRoleId      Int?
  parent            CareerRole?            @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  children          CareerRole[]           @relation("RoleHierarchy")
  active            Boolean                @default(true)
  skillRequirements RoleSkillRequirement[]
  fromRules         ProgressionRule[]      @relation("FromRole")
  toRules           ProgressionRule[]      @relation("ToRole")
  pathSteps         CareerPathStep[]
  plans             UserCareerPlan[]       @relation("CurrentRole")
  targetPlans       UserCareerPlan[]       @relation("TargetRole")
  promotions        PromotionRequest[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([department, level])
}

model CareerPosition {
  id           Int                  @id @default(autoincrement())
  title        String
  description  String               @db.Text
  level        String
  createdAt    DateTime             @default(now())
  competencies PositionCompetency[]
  users        UserCareer[]
  @@index([level])
}

model UserCareer {
  id         Int            @id @default(autoincrement())
  userId     Int
  positionId Int
  startedAt  DateTime       @default(now())
  endedAt    DateTime?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  position   CareerPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([positionId])
}

model CareerSkill {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  type        SkillType
  category    String?
  maxLevel    Int          @default(5)
  active      Boolean      @default(true)
  goals       CareerGoal[]
  createdAt   DateTime     @default(now())
}

model CareerPath {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  active      Boolean          @default(true)
  plans       UserCareerPlan[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  type         String   // LINEAR|Y_SHAPED|T_SHAPED|W_SHAPED|LATTICE
  departmentId Int?
  department Department?    @relation(fields: [departmentId], references: [id])
  steps       CareerPathStep[] 
  @@index([active])
  @@index([departmentId])
}

model CareerPathStep {
  id     Int        @id @default(autoincrement())
  roleId Int
  role   CareerRole @relation(fields: [roleId], references: [id])
  order  Int
  label  String?
  careerPathId          Int
  positionId            Int
  minMonthsRequired     Int?
  minPerformanceScore   Float?
  requiredCourseIds     Int[]  @default([])
  requiredCompetencyIds Int[]  @default([])
  careerPath CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  position   Position   @relation(fields: [positionId],   references: [id])
  @@unique([careerPathId, order])
  @@index([careerPathId])
}

model InternalApplication {
  id         Int      @id @default(autoincrement())
  vacancyId  Int
  userId     Int
  motivation String?  @db.Text
  status     String   @default("PENDING") // PENDING|REVIEWING|SHORTLISTED|REJECTED|ACCEPTED
  feedback   String?
  appliedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vacancy InternalVacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId],    references: [id])
  @@unique([vacancyId, userId])
  @@index([userId])
  @@index([status])
}

model InternalVacancy {
  id                    Int       @id @default(autoincrement())
  title                 String
  description           String?   @db.Text
  type                  String    // PROMOTION|LATERAL|GIG_PROJECT|JOB_ROTATION|SHADOWING
  status                String    @default("DRAFT")
  positionId            Int?
  departmentId          Int?
  createdById           Int
  slots                 Int       @default(1)
  closingDate           DateTime?
  durationDays          Int?
  publishedAt           DateTime?
  requiredCompetencyIds Int[]     @default([])
  requiredCourseIds     Int[]     @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  position     Position?              @relation(fields: [positionId],   references: [id])
  department   Department?            @relation(fields: [departmentId], references: [id])
  createdBy    User                   @relation("VacancyCreator", fields: [createdById], references: [id])
  applications InternalApplication[]
  @@index([status])
  @@index([type])
  @@index([departmentId])
}

model ProgressionRule {
  id                        Int        @id @default(autoincrement())
  fromRoleId                Int
  fromRole                  CareerRole @relation("FromRole", fields: [fromRoleId], references: [id])
  toRoleId                  Int
  toRole                    CareerRole @relation("ToRole", fields: [toRoleId], references: [id])
  minMonthsInRole           Int?
  minPerformanceScore       Float?
  minCompletedProjects      Int?
  requiresManagerApproval   Boolean    @default(true)
  requiresHrApproval        Boolean    @default(true)
  requiresCommitteeApproval Boolean    @default(false)
  active                    Boolean    @default(true)
  createdAt                 DateTime   @default(now())

  @@unique([fromRoleId, toRoleId])
}

model CareerGoal {
  id           Int            @id @default(autoincrement())
  careerPlanId Int
  careerPlan   UserCareerPlan @relation(fields: [careerPlanId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  type         GoalType       @default(OTHER)
  status       GoalStatus     @default(PENDING)
  progress     Int            @default(0)
  skillId      Int?
  skill        CareerSkill?   @relation(fields: [skillId], references: [id])
  courseId     Int?
  dueDate      DateTime?
  resourceUrl  String?
  notes        String?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([careerPlanId, status])
}

model PromotionRequest {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation("PromotionRequester", fields: [userId], references: [id])
  targetRoleId   Int
  targetRole     CareerRole      @relation(fields: [targetRoleId], references: [id])
  careerPlanId   Int?
  careerPlan     UserCareerPlan? @relation(fields: [careerPlanId], references: [id])
  justification  String
  readinessScore Float?
  status         PromotionStatus @default(PENDING)
  reviewNotes    String?
  reviewedById   Int?
  reviewedBy     User?           @relation("PromotionReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  effectiveDate  DateTime?
  requestedById  Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
}

model SuccessionPlan {
  id                  Int      @id @default(autoincrement())
  criticalPositionId  Int
  candidateId         Int
  readinessLevel      String   // READY_NOW|READY_SOON|NEEDS_DEVELOPMENT
  priority            String   // PRIMARY|SECONDARY|TERTIARY
  matchScore          Float?
  geographicMobility  Boolean  @default(true)
  available           Boolean  @default(true)
  notes               String?
  readinessByDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  criticalPosition CriticalPosition @relation(fields: [criticalPositionId], references: [id], onDelete: Cascade)
  candidate        User             @relation(fields: [candidateId],        references: [id])
  pdi              SuccessionPDI?
  positionId  Int       // ou String — verificar o tipo de Position.id
  position    Position  @relation(fields: [positionId], references: [id])
  @@unique([criticalPositionId, candidateId])
  @@index([readinessLevel])
  @@index([candidateId])
}

model TalentPool {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  readinessLevel      String
  mentorId            Int?
  notes               String?
  geographicMobility  Boolean  @default(true)
  createdAt           DateTime @default(now())
  user   User  @relation(fields: [userId],   references: [id])
  mentor User? @relation("TalentPoolMentor", fields: [mentorId], references: [id])
}

model SuccessionPDI {
  id                Int      @id @default(autoincrement())
  successionPlanId  Int      @unique
  gaps              String   // JSON
  developmentGoals  String?
  learningPathIds   Int[]
  courseIds         Int[]
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  successionPlan SuccessionPlan @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
}

model CriticalPosition {
  id                  Int      @id @default(autoincrement())
  positionId          Int      @unique
  businessImpact      String   // LOW|MEDIUM|HIGH|CRITICAL
  replacementTime     String   // IMMEDIATE|SHORT_TERM|MEDIUM_TERM|LONG_TERM
  exitRisk            String   // LOW|MEDIUM|HIGH|CRITICAL
  expectedExitDate    DateTime?
  criticalReason      String?
  keyPersonRisk       Boolean  @default(false)
  minSuccessorsRequired Int    @default(2)
  requiresDocumentation Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  position       Position         @relation(fields: [positionId],  references: [id])
  successionPlans SuccessionPlan[]
  @@index([exitRisk])
  @@index([businessImpact])
}

model DevelopmentPlan {
  id                 Int                     @id @default(autoincrement())
  name               String
  goal               String                  @db.Text
  userId             Int
  managerId          Int?
  priority           String                  @default("MEDIUM")
  status             String                  @default("DRAFT")
  period             String?
  startDate          DateTime?
  endDate            DateTime?
  completedAt        DateTime?
  activatedAt        DateTime?
  cancelReason       String?
  performanceCycleId Int?
  overallProgress    Int                     @default(0)
  isTemplate         Boolean                 @default(false)
  notes              String?                 @db.Text
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id])
  manager            User?                   @relation("PDIManager", fields: [managerId], references: [id])
  actions            DevelopmentPlanAction[]
  goals              PdiGoal[]
  checkpoints        PdiCheckpoint[]
  approvals          PdiApproval[]
  pdiActions         PdiAction[]
  certificates       Certificate[]
  @@index([userId])
  @@index([status])
  @@index([managerId])
}

model DevelopmentPlanAction {
  id            Int             @id @default(autoincrement())
  planId        Int
  title         String
  description   String?         @db.Text
  type          String
  status        String          @default("TODO")
  courseId      Int?
  workloadHours Int?
  dueDate       DateTime?
  completedAt   DateTime?
  resources     String[]
  xpReward      Int             @default(20)
  seq           Int             @default(0)
  mandatory     Boolean         @default(false)
  progress      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  plan          DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  evidence      PdiEvidence[]

  @@index([planId])
  @@index([status])
}

model PdiEvidence {
  id            Int                  @id @default(autoincrement())
  developmentPlanActionId  Int  
  developmentPlanAction    DevelopmentPlanAction @relation(fields: [developmentPlanActionId], references: [id], onDelete: Cascade)
  submittedById Int
  title         String
  url           String?
  notes         String?               @db.Text
  evidenceType  String                @default("NOTE")
  createdAt     DateTime              @default(now())
  submittedBy   User                  @relation(fields: [submittedById], references: [id])
  @@index([developmentPlanActionId])
}

model PdiAction {
  id           Int       @id @default(autoincrement())
  planId       Int
  title        String
  description  String?   @db.Text
  type         String    // COURSE|MENTORING|COACHING|READING|PROJECT|JOB_ROTATION|MICROLEARNING|WORKSHOP|CERTIFICATION|OTHER
  status       String    @default("TODO")              // TODO|IN_PROGRESS|COMPLETED|BLOCKED|CANCELLED
  courseId     Int?
  workloadHours Int?
  dueDate      DateTime?
  completedAt  DateTime?
  resources    String[]
  xpReward     Int       @default(20)
  seq          Int       @default(0)
  mandatory    Boolean   @default(false)
  progress     Int       @default(0)                   // 0-100
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  plan     DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  @@index([planId])
  @@index([status])
}

model PdiGoal {
  id               Int             @id @default(autoincrement())
  planId           Int
  title            String
  description      String?
  successIndicator String?
  progress         Int             @default(0)
  weight           Int             @default(100)
  notes            String?
  dueDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  plan             DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model PdiCheckpoint {
  id          Int             @id @default(autoincrement())
  planId      Int
  title       String
  description String?
  type        String          @default("QUICK")
  status      String          @default("PENDING")
  scheduledAt DateTime
  completedAt DateTime?
  selfScore   Int?
  notes       String?
  createdAt   DateTime        @default(now())
  plan        DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([scheduledAt])
}

model PdiApproval {
  id         Int             @id @default(autoincrement())
  planId     Int
  approverId Int
  decision   String
  comment    String?
  createdAt  DateTime        @default(now())
  plan       DevelopmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  approver   User            @relation(fields: [approverId], references: [id])

  @@index([planId])
}

// ══════════════════════════════════════════════════════════════════
// APRENDIZAGEM — CURSOS, MÓDULOS, AULAS
// ══════════════════════════════════════════════════════════════════

model Course {
  id                      Int       @id @default(autoincrement())
  title                   String
  shortDescription        String?
  description             String?   @db.Text
  category                String?
  tags                    String[]
  thumbnailUrl            String?
  introVideoUrl           String?
  workloadHours           Int?
  language                String    @default("pt")
  level                   String    @default("BEGINNER")
  status                  String    @default("DRAFT")
  mandatory               Boolean   @default(false)
  internalCode            String?   @unique
  departmentId            Int?
  learningObjectives      String[]
  passingScore            Int?
  certificateValidityDays Int?
  allowDownload           Boolean   @default(false)
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  department      Department?          @relation(fields: [departmentId], references: [id])
  modules         CourseModule[]
  enrollments     Enrollment[]
  feedbacks       CourseFeedback[]
  competencies    CourseCompetency[]
  analytics       CourseAnalytics?
  certificates    Certificate[]
  assessments     Assessment[]
  evaluations     Evaluation[]
  aiSessions      AiTutorSession[]
  liveClasses     LiveClass[]
  trainingImpacts TrainingImpact[]
  learningPaths   LearningPathCourse[]
  cohorts         InstructorCohort[]

  @@index([status])
  @@index([category])
  @@index([mandatory])
  @@index([createdAt])
}

model CourseModule {
  id                   Int       @id @default(autoincrement())
  courseId             Int
  title                String
  description          String?
  learningObjectives   String[]
  seq                  Int
  status               String    @default("DRAFT")
  type                 String?
  progressionType      String    @default("SEQUENTIAL")
  completionRule       String    @default("ALL_LESSONS")
  minCompletionPercent Int       @default(100)
  minQuizScore         Int?
  mandatory            Boolean   @default(true)
  dripDays             Int?
  availableFrom        DateTime?
  createdAt            DateTime  @default(now())
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  materials   ModuleMaterial[]
  assessments Assessment[]
  @@index([courseId])
  @@index([seq])
}

model Lesson {
  id              Int      @id @default(autoincrement())
  moduleId        Int
  title           String
  description     String?
  type            String   @default("VIDEO")
  contentUrl      String?  @db.Text
  textContent     String?  @db.Text
  seq             Int
  durationMinutes Int?
  isFree          Boolean  @default(false)
  allowDownload   Boolean  @default(false)
  createdAt       DateTime @default(now())
  content         String?  @db.Text
  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  quiz     Quiz?

  @@index([moduleId])
}

model LessonProgress {
  id             Int       @id @default(autoincrement())
  lessonId       Int
  userId         Int
  enrollmentId   Int?
  completed      Boolean   @default(false)
  completedAt    DateTime?
  watchedSeconds Int?
  resumePosition Int?
  lesson     Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  @@unique([lessonId, userId])
  @@index([userId])
  @@index([userId, completed])
  @@index([enrollmentId])
}

model ModuleMaterial {
  id         Int          @id @default(autoincrement())
  moduleId   Int
  title      String
  url        String
  fileType   String?
  fileSizeKb Int?
  createdAt  DateTime     @default(now())
  module     CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id             Int       @id @default(autoincrement())
  courseId       Int
  userId         Int
  status         String    @default("NOT_STARTED")
  origin         String    @default("MANUAL")
  mandatory      Boolean   @default(false)
  learningPathId Int?
  assignedById   Int?
  deadline       DateTime?
  enrolledAt     DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  progress       Int  @default(0)
  course      Course              @relation(fields: [courseId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  certificate Certificate?
  progresses  LessonProgress[]
  attempts    EvaluationAttempt[] @relation("EnrollmentAttempts")
  aiSessions  AiTutorSession[]

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([deadline])
  @@index([mandatory])
}

model Certificate {
  id                Int                @id @default(autoincrement())
  type              CertificateType
  userId            Int?
  enrollmentId      Int?               @unique
  courseId          Int?
  programId         Int?
  developmentPlanId Int?
  issuedAt          DateTime           @default(now())
  code              String?            @unique
  validationCode    String             @unique
  fileUrl           String?            @db.Text
  expiresAt         DateTime?
  revoked           Boolean            @default(false)
  user              User?              @relation(fields: [userId], references: [id])
  enrollment        Enrollment?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course            Course?            @relation(fields: [courseId], references: [id])
  program           LeadershipProgram? @relation(fields: [programId], references: [id])
  developmentPlan   DevelopmentPlan?   @relation(fields: [developmentPlanId], references: [id])
  eventId           Int?
  event             Event?             @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([enrollmentId])
}

model Quiz {
  id               Int            @id @default(autoincrement())
  lessonId         Int            @unique
  title            String
  passingScore     Int            @default(70)
  maxAttempts      Int            @default(0)
  timeLimitMinutes Int?
  lesson           Lesson         @relation(fields: [lessonId], references: [id])
  questions        QuizQuestion[]
  attempts         QuizAttempt[]
}

model QuizQuestion {
  id            Int     @id @default(autoincrement())
  quizId        Int
  question      String
  type          String
  options       String?
  correctAnswer String?
  points        Int     @default(1)
  seq           Int
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  quizId      Int
  userId      Int
  score       Int
  passed      Boolean
  answers     String
  results     String
  submittedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
}

model CourseCompetency {
  id           Int        @id @default(autoincrement())
  courseId     Int
  competencyId Int
  levelGained  Int        @default(1)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([courseId, competencyId])
}

model CourseAnalytics {
  id               Int      @id @default(autoincrement())
  courseId         Int      @unique
  totalEnrollments Int      @default(0)
  totalCompleted   Int      @default(0)
  avgRating        Float    @default(0)
  totalRatings     Int      @default(0)
  updatedAt        DateTime @updatedAt
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseFeedback {
  id        Int      @id @default(autoincrement())
  courseId  Int
  userId    Int
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
}

// ══════════════════════════════════════════════════════════════════
// TRILHAS DE APRENDIZAGEM
// ══════════════════════════════════════════════════════════════════

model LearningPath {
  id               Int       @id @default(autoincrement())
  title            String
  shortDescription String?
  description      String?   @db.Text
  objective        String?
  thumbnailUrl     String?
  category         String?
  tags             String[]
  level            String    @default("BEGINNER")
  pathType         String    @default("CUSTOM")
  progressionType  String    @default("SEQUENTIAL")
  status           String    @default("DRAFT")
  mandatory        Boolean   @default(false)
  language         String    @default("pt")
  totalHours       Int       @default(0)
  deadline         DateTime?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  courses     LearningPathCourse[]
  milestones  LearningPathMilestone[]
  assignments LearningPathAssignment[]
  enrollments LearningPathEnrollment[]
  @@index([status])
  @@index([category])
}

model LearningPathCourse {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  courseId       Int
  seq            Int
  required       Boolean      @default(true)
  milestoneId    Int?
  deadlineDays   Int?
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id])
  @@unique([learningPathId, courseId])
  @@index([learningPathId])
}

model LearningPathMilestone {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  title          String
  description    String?
  seq            Int
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
}

model LearningPathAssignment {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  targetType     String
  targetId       Int
  mandatory      Boolean      @default(false)
  deadline       DateTime?
  createdAt      DateTime     @default(now())
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id])

  @@index([learningPathId])
}

model LearningPathEnrollment {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  userId         Int
  status         String       @default("NOT_STARTED")
  mandatory      Boolean      @default(false)
  deadline       DateTime?
  enrolledAt     DateTime     @default(now())
  completedAt    DateTime?
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([learningPathId, userId])
  @@index([status])
  @@index([userId])
}

// ══════════════════════════════════════════════════════════════════
// AVALIAÇÕES (ASSESSMENTS)
// ══════════════════════════════════════════════════════════════════

model Assessment {
  id                 Int      @id @default(autoincrement())
  title              String
  description        String?
  type               String   @default("QUIZ")
  status             String   @default("DRAFT")
  courseId           Int?
  moduleId           Int?
  learningPathId     Int?
  passingScore       Int      @default(70)
  maxAttempts        Int      @default(0)
  cooldownHours      Int      @default(0)
  timeLimitMinutes   Int      @default(0)
  feedbackMode       String   @default("ON_SUBMIT")
  randomizeQuestions Boolean  @default(false)
  randomizeOptions   Boolean  @default(false)
  allowReview        Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  course    Course?              @relation(fields: [courseId], references: [id])
  module    CourseModule?        @relation(fields: [moduleId], references: [id])
  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]
  @@index([courseId])
  @@index([status])
}

model AssessmentQuestion {
  id            Int                       @id @default(autoincrement())
  assessmentId  Int
  type          String
  questionText  String
  mediaUrl      String?
  options       String?
  correctAnswer String?
  explanation   String?
  weight        Float                     @default(1)
  mandatory     Boolean                   @default(false)
  difficulty    Int                       @default(1)
  tags          String[]
  seq           Int
  assessment    Assessment                @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers       AssessmentAttemptAnswer[]
  @@index([assessmentId])
}

model AssessmentAttempt {
  id                Int                       @id @default(autoincrement())
  assessmentId      Int
  userId            Int
  status            String                    @default("IN_PROGRESS")
  score             Int?
  passed            Boolean?
  startedAt         DateTime                  @default(now())
  submittedAt       DateTime?
  deadline          DateTime?
  timeSpentMinutes  Int?
  questionOrder     String?
  savedAnswers      String                    @default("{}")
  lastSavedAt       DateTime?
  needsManualReview Boolean                   @default(false)
  assessment        Assessment                @relation(fields: [assessmentId], references: [id])
  user              User                      @relation(fields: [userId], references: [id])
  answers           AssessmentAttemptAnswer[]
  @@index([userId])
  @@index([assessmentId])
  @@index([status])
}

model AssessmentAttemptAnswer {
  id              Int                @id @default(autoincrement())
  attemptId       Int
  questionId      Int
  selectedIndices String?
  textAnswer      String?
  fileUrl         String?
  isCorrect       Boolean?
  earnedPoints    Float              @default(0)
  needsReview     Boolean            @default(false)
  manualScore     Float?
  reviewComment   String?
  reviewedById    Int?
  reviewedAt      DateTime?
  attempt         AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        AssessmentQuestion @relation(fields: [questionId], references: [id])
  @@unique([attemptId, questionId])
}

// ══════════════════════════════════════════════════════════════════
// COMPETÊNCIAS
// ══════════════════════════════════════════════════════════════════

model Competency {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  category    String   @default("HARD_SKILL")
  tags        String[]
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userCompetencies  UserCompetency[]
  courses           CourseCompetency[]
  positions         PositionCompetency[]
  proficiencyLevels ProficiencyLevel[]
  endorsements      CompetencyEndorsement[]
  evolutionLogs     CompetencyEvolutionLog[]
  competencyMaps    CompetencyMap[]
  avatarScenarios   AvatarScenario[]
  @@index([category])
  @@index([status])
}

model ProficiencyLevel {
  id           Int        @id @default(autoincrement())
  competencyId Int
  name         String
  value        Int
  description  String?
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  @@unique([competencyId, value])
}

model UserCompetency {
  id           Int        @id @default(autoincrement())
  userId       Int
  competencyId Int
  currentLevel Int        @default(0)
  targetLevel  Int?
  selfLevel    Int?
  managerLevel Int?
  source       String     @default("MANUAL")
  notes        String?
  evidenceUrl  String?
  evaluatedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  competency   Competency @relation(fields: [competencyId], references: [id])
  @@unique([userId, competencyId])
  @@index([userId])
}

model CompetencyEvolutionLog {
  id            Int        @id @default(autoincrement())
  userId        Int
  competencyId  Int
  previousLevel Int
  newLevel      Int
  source        String
  updatedById   Int?
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id])
  competency    Competency @relation(fields: [competencyId], references: [id])

  @@index([userId])
  @@index([competencyId])
}

model CompetencyEndorsement {
  id           Int        @id @default(autoincrement())
  endorserId   Int
  userId       Int
  competencyId Int
  comment      String?
  createdAt    DateTime   @default(now())
  endorser     User       @relation("EndorsementGiven", fields: [endorserId], references: [id])
  user         User       @relation("EndorsementReceived", fields: [userId], references: [id])
  competency   Competency @relation(fields: [competencyId], references: [id])

  @@unique([endorserId, userId, competencyId])
}

model PositionCompetency {
  id               Int             @id @default(autoincrement())
  positionId       Int?
  careerPositionId Int?
  competencyId     Int
  requiredLevel    Int
  priority         String          @default("MANDATORY")
  weight           Float           @default(1)
  position         Position?       @relation(fields: [positionId], references: [id])
  careerPosition   CareerPosition? @relation(fields: [careerPositionId], references: [id])
  competency       Competency      @relation(fields: [competencyId], references: [id])
}

model CompetencyMap {
  id           Int        @id @default(autoincrement())
  userId       Int
  competencyId Int
  currentLevel Int
  targetLevel  Int
  assessedById Int?
  notes        String?    @db.Text
  assessedAt   DateTime   @default(now())
  user         User       @relation("UserCompetencyMaps", fields: [userId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  assessedBy   User?      @relation("AssessedCompetencyMaps", fields: [assessedById], references: [id], onDelete: SetNull)

  @@unique([userId, competencyId])
  @@index([userId])
  @@index([competencyId])
}

// ══════════════════════════════════════════════════════════════════
// PERFORMANCE
// ══════════════════════════════════════════════════════════════════

model PerformanceCycle {
  id                  Int       @id @default(autoincrement())
  name                String
  type                String
  status              String    @default("PLANNED")
  startDate           DateTime
  endDate             DateTime
  selfEvalDeadline    DateTime?
  managerEvalDeadline DateTime?
  goalsWeight         Int       @default(40)
  competenciesWeight  Int       @default(40)
  behaviorsWeight     Int       @default(20)
  selfBeforeManager   Boolean   @default(true)
  anonymous360        Boolean   @default(true)
  scoreScale          Int       @default(5)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  reviews  PerformanceReview[]
  goals    PerformanceGoal[]
  feedback ContinuousFeedback[]
  nineBox  NineBoxPlacement[]

  @@index([status])
}

model PerformanceReview {
  id             Int       @id @default(autoincrement())
  userId         Int
  cycleId        Int
  reviewerId     Int?
  type           String
  status         String    @default("PENDING_SELF")
  score          Float?
  potentialScore Int?
  feedback       String?
  justification  String?
  category       String?
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User             @relation("ReviewedUser", fields: [userId], references: [id])
  reviewer User?            @relation("ReviewerUser", fields: [reviewerId], references: [id])
  cycle    PerformanceCycle @relation(fields: [cycleId], references: [id])

  goals           GoalEvaluation[]
  competencyEvals CompetencyEvaluation[]
  calibrationLogs CalibrationLog[]
  disputes        PerformanceDispute[]

  @@unique([userId, cycleId, type])
  @@index([userId])
  @@index([status])
}

model PerformanceGoal {
  id           Int       @id @default(autoincrement())
  userId       Int
  cycleId      Int
  title        String
  description  String?
  targetValue  Float
  currentValue Float     @default(0)
  progress     Int       @default(0)
  weight       Float     @default(100)
  unit         String?
  status       String    @default("ON_TRACK")
  notes        String?
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User             @relation(fields: [userId], references: [id])
  cycle       PerformanceCycle @relation(fields: [cycleId], references: [id])
  evaluations GoalEvaluation[]

  @@index([userId])
}

model GoalEvaluation {
  id       Int               @id @default(autoincrement())
  reviewId Int
  goalId   Int
  score    Float
  comment  String?
  review   PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  goal     PerformanceGoal   @relation(fields: [goalId], references: [id])

  @@unique([reviewId, goalId])
}

model CompetencyEvaluation {
  id             Int               @id @default(autoincrement())
  reviewId       Int
  competencyId   Int
  evaluatedLevel Int
  feedback       String?
  review         PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, competencyId])
}

model ContinuousFeedback {
  id            Int               @id @default(autoincrement())
  giverId       Int
  userId        Int
  cycleId       Int?
  type          String
  message       String
  visibleToUser Boolean           @default(true)
  createdAt     DateTime          @default(now())
  giver         User              @relation("FeedbackGiver", fields: [giverId], references: [id])
  user          User              @relation("FeedbackReceived", fields: [userId], references: [id])
  cycle         PerformanceCycle? @relation(fields: [cycleId], references: [id])

  @@index([userId])
}

model CalibrationLog {
  id              Int               @id @default(autoincrement())
  reviewId        Int
  calibratorId    Int
  previousScore   Float?
  calibratedScore Float
  reason          String
  createdAt       DateTime          @default(now())
  review          PerformanceReview @relation(fields: [reviewId], references: [id])
  calibrator      User              @relation(fields: [calibratorId], references: [id])
}

model PerformanceDispute {
  id         Int               @id @default(autoincrement())
  reviewId   Int
  userId     Int
  reason     String
  evidence   String?
  status     String            @default("OPEN")
  resolution String?
  createdAt  DateTime          @default(now())
  review     PerformanceReview @relation(fields: [reviewId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
}

model NineBoxPlacement {
  id              Int               @id @default(autoincrement())
  userId          Int
  cycleId         Int?
  performanceAxis Int
  potentialAxis   Int
  justification   String
  updatedById     Int
  updatedAt       DateTime          @default(now())
  user            User              @relation("NineBoxUser", fields: [userId], references: [id])
  cycle           PerformanceCycle? @relation(fields: [cycleId], references: [id])
  updatedBy       User              @relation("NineBoxUpdater", fields: [updatedById], references: [id])

  @@unique([userId, cycleId])
}

model PerformanceEvaluation {
  id             Int      @id @default(autoincrement())
  evaluatorId    Int
  evaluatedId    Int
  type           EvalType
  period         String
  criteria       Json
  generalComment String?  @db.Text
  overallScore   Float    @default(0)
  createdAt      DateTime @default(now())
  evaluator      User     @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  evaluated      User     @relation("EvaluatedRelation", fields: [evaluatedId], references: [id])

  @@index([evaluatedId])
  @@index([evaluatorId])
  @@index([period])
}

model EvaluationRequest {
  id          Int       @id @default(autoincrement())
  evaluatorId Int
  evaluatedId Int
  status      String    @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  evaluator   User      @relation("RequestEvaluator", fields: [evaluatorId], references: [id])
  evaluated   User      @relation("RequestEvaluated", fields: [evaluatedId], references: [id])

  @@index([evaluatorId])
  @@index([evaluatedId])
}

// ══════════════════════════════════════════════════════════════════
// LIDERANÇA
// ══════════════════════════════════════════════════════════════════

model LeadershipProgram {
  id                 Int       @id @default(autoincrement())
  name               String
  description        String?   @db.Text
  level              String
  status             String    @default("DRAFT")
  durationWeeks      Int?
  learningPathId     Int?
  mandatory          Boolean   @default(false)
  minLeadershipScore Int?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  participants LeadershipParticipant[]
  certificates Certificate[]

  @@index([level])
  @@index([status])
}

model LeadershipParticipant {
  id          Int               @id @default(autoincrement())
  userId      Int
  programId   Int
  progress    Int               @default(0)
  status      String            @default("ENROLLED")
  notes       String?
  enrolledAt  DateTime          @default(now())
  completedAt DateTime?
  user        User              @relation(fields: [userId], references: [id])
  program     LeadershipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
}

model OneOnOne {
  id              Int       @id @default(autoincrement())
  managerId       Int
  subordinateId   Int
  scheduledAt     DateTime
  durationMinutes Int       @default(30)
  status          String    @default("SCHEDULED")
  agenda          String?
  meetingUrl      String?
  minutes         String?
  actionItems     String?
  nextMeetingDate DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  manager         User      @relation("OneOnOneManager", fields: [managerId], references: [id])
  subordinate     User      @relation("OneOnOneSubordinate", fields: [subordinateId], references: [id])

  @@index([managerId])
}

model LeadershipFeedback360 {
  id                  Int                             @id @default(autoincrement())
  leaderId            Int
  respondentId        Int?
  cycleId             Int?
  anonymous           Boolean                         @default(false)
  qualitativeFeedback String?
  createdAt           DateTime                        @default(now())
  leader              User                            @relation("LeaderFeedback", fields: [leaderId], references: [id])
  responses           LeadershipFeedback360Response[]

  @@index([leaderId])
}

model LeadershipFeedback360Response {
  id         Int                   @id @default(autoincrement())
  feedbackId Int
  competency String
  score      Int
  feedback   LeadershipFeedback360 @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model LeadershipPulse {
  id           Int      @id @default(autoincrement())
  leaderId     Int
  respondentId Int
  overallScore Int
  q1           String?
  q2           String?
  q3           String?
  month        Int
  year         Int
  createdAt    DateTime @default(now())

  @@unique([leaderId, respondentId, month, year])
  @@index([leaderId])
}

model LeadershipScore {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  score          Int      @default(0)
  classification String   @default("AVERAGE")
  calculatedAt   DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model Mentoring {
  id               Int                @id @default(autoincrement())
  mentorId         Int
  menteeId         Int
  objective        String?
  durationMonths   Int?
  reverseMentoring Boolean            @default(false)
  status           String             @default("ACTIVE")
  startedAt        DateTime           @default(now())
  completedAt      DateTime?
  mentor           User               @relation("MentoringMentor", fields: [mentorId], references: [id])
  mentee           User               @relation("MentoringMentee", fields: [menteeId], references: [id])
  sessions         MentoringSession[]

  @@index([mentorId])
  @@index([menteeId])
}

model MentoringSession {
  id              Int       @id @default(autoincrement())
  mentoringId     Int
  sessionDate     DateTime
  durationMinutes Int?
  summary         String
  actionItems     String?
  rating          Int?
  createdAt       DateTime  @default(now())
  mentoring       Mentoring @relation(fields: [mentoringId], references: [id], onDelete: Cascade)
}

model TeamHealth {
  id                   Int      @id @default(autoincrement())
  managerId            Int      @unique
  engagementScore      Float?
  turnoverRate         Float?
  absenteeismRate      Float?
  pdisCompletedPct     Float?
  evaluationsOnTimePct Float?
  updatedAt            DateTime @default(now())
}

model Kudos {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  message    String
  badge      String?
  createdAt  DateTime @default(now())
  sender     User     @relation("KudosSender", fields: [senderId], references: [id])
  receiver   User     @relation("KudosReceiver", fields: [receiverId], references: [id])

  @@index([receiverId])
}

// ══════════════════════════════════════════════════════════════════
// ONBOARDING
// ══════════════════════════════════════════════════════════════════

model OnboardingTemplate {
  id              Int                      @id @default(autoincrement())
  name            String
  description     String?
  positionId      Int?
  departmentId    Int?
  durationDays    Int                      @default(30)
  learningPathId  Int?
  welcomeVideoUrl String?
  active          Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  position        Position?                @relation(fields: [positionId], references: [id])
  department      Department?              @relation(fields: [departmentId], references: [id])
  tasks           OnboardingTemplateTask[]
  plans           OnboardingPlan[]

  @@index([active])
}

model OnboardingTemplateTask {
  id               Int                      @id @default(autoincrement())
  templateId       Int
  title            String
  description      String?
  category         String
  type             String
  phase            String
  responsible      String
  dueDayOffset     Int?
  dependsOn        Int[]
  courseId         Int?
  processId        Int?
  xpReward         Int                      @default(10)
  requiresApproval Boolean                  @default(false)
  requiresEvidence Boolean                  @default(false)
  seq              Int
  template         OnboardingTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instances        OnboardingTaskInstance[]

  @@index([templateId])
}

model OnboardingPlan {
  id              Int                      @id @default(autoincrement())
  userId          Int
  templateId      Int
  status          String                   @default("NOT_STARTED")
  startDate       DateTime                 @default(now())
  expectedEndDate DateTime?
  completedAt     DateTime?
  buddyId         Int?
  managerId       Int?
  hrResponsibleId Int?
  xpEarned        Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User  @relation("OnboardingPlanUser", fields: [userId], references: [id])
  template        OnboardingTemplate       @relation(fields: [templateId], references: [id])
  buddy           User?                    @relation("OnboardingBuddy", fields: [buddyId], references: [id])
  manager         User?                    @relation("OnboardingManager", fields: [managerId], references: [id])
  hrResponsible   User?                    @relation("OnboardingHR", fields: [hrResponsibleId], references: [id])
  taskInstances   OnboardingTaskInstance[]
  documents       OnboardingDocument[]
  surveys         OnboardingSurvey[]
  @@index([userId])
  @@index([status])
}

model OnboardingTaskInstance {
  id              Int                    @id @default(autoincrement())
  planId          Int
  templateTaskId  Int
  status          String                 @default("PENDING")
  dueDate         DateTime?
  completedAt     DateTime?
  evidenceComment String?
  evidenceUrl     String?
  skipReason      String?
  approvedById    Int?
  approvedAt      DateTime?
  approvalNote    String?
  createdAt       DateTime               @default(now())
  plan            OnboardingPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  templateTask    OnboardingTemplateTask @relation(fields: [templateTaskId], references: [id])
  approvedBy      User?                  @relation("TaskApprover", fields: [approvedById], references: [id])

  @@unique([planId, templateTaskId])
  @@index([planId])
}

model OnboardingDocument {
  id              Int            @id @default(autoincrement())
  planId          Int
  documentType    String
  fileUrl         String
  notes           String?
  status          String         @default("PENDING")
  uploadedById    Int
  validatedById   Int?
  validatedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  plan            OnboardingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation("DocUploader", fields: [uploadedById], references: [id])
  validatedBy     User?          @relation("DocValidator", fields: [validatedById], references: [id])
}

model OnboardingSurvey {
  id        Int            @id @default(autoincrement())
  planId    Int
  milestone String
  score     Int
  enps      Int?
  comment   String?
  createdAt DateTime       @default(now())
  plan      OnboardingPlan @relation(fields: [planId], references: [id])

  @@unique([planId, milestone])
}

// ══════════════════════════════════════════════════════════════════
// MICRO-LEARNING
// ══════════════════════════════════════════════════════════════════

model MicroLearning {
  id              Int       @id @default(autoincrement())
  title           String    @db.VarChar(80)
  description     String?   @db.VarChar(200)
  contentType     String
  level           String
  status          String    @default("DRAFT")
  durationSeconds Int?
  mediaUrl        String?
  textContent     String?   @db.Text
  thumbnailUrl    String?
  tags            String[]
  takeaways       String[]
  xpReward        Int       @default(10)
  viewCount       Int       @default(0)
  categoryId      Int?
  learningPathId  Int?
  authorId        Int?
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  author        User?                      @relation(fields: [authorId], references: [id])
  quizQuestions MicroQuizQuestion[]
  progress      MicroLearningProgress[]
  interactions  MicroLearningInteraction[]
  quizAttempts  MicroQuizAttempt[]
  @@index([status])
  @@index([contentType])
  @@index([viewCount])
}

model MicroQuizQuestion {
  id              Int           @id @default(autoincrement())
  microLearningId Int
  question        String
  options         String
  explanation     String?
  seq             Int
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id], onDelete: Cascade)
}

model MicroLearningProgress {
  id              Int           @id @default(autoincrement())
  userId          Int
  microLearningId Int
  progress        Int           @default(0)
  watchedSeconds  Int           @default(0)
  completedAt     DateTime?
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id])
  @@unique([userId, microLearningId])
  @@index([userId])
}

model MicroLearningInteraction {
  id              Int           @id @default(autoincrement())
  userId          Int
  microLearningId Int
  action          String
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id])

  @@index([userId])
  @@index([microLearningId])
}

model MicroQuizAttempt {
  id              Int           @id @default(autoincrement())
  userId          Int
  microLearningId Int
  score           Int
  answers         String
  completedAt     DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id])
}

model MicroLearningPlaylist {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  authorId    Int
  createdAt   DateTime       @default(now())
  author      User           @relation(fields: [authorId], references: [id])
  items       PlaylistItem[]
}

model PlaylistItem {
  id              Int                   @id @default(autoincrement())
  playlistId      Int
  microLearningId Int
  seq             Int
  playlist        MicroLearningPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, microLearningId])
}

model LearningStreak {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  user             User      @relation(fields: [userId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
// TREINAMENTOS
// ══════════════════════════════════════════════════════════════════

model Training {
  id                     Int       @id @default(autoincrement())
  title                  String
  shortDescription       String?
  description            String?   @db.Text
  objectives             String?
  targetAudience         String?
  type                   String
  level                  String
  status                 String    @default("DRAFT")
  category               String?
  tags                   String[]
  language               String    @default("pt")
  workloadHours          Float?
  thumbnailUrl           String?
  prerequisites          String?
  instructorId           Int?
  mandatory              Boolean   @default(false)
  passingScore           Int       @default(70)
  issueCertificate       Boolean   @default(false)
  cost                   Float?
  completionDeadlineDays Int?
  startDate              DateTime?
  endDate                DateTime?
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  instructor   User?                 @relation(fields: [instructorId], references: [id])
  sessions     TrainingSession[]
  participants TrainingParticipant[]
  ratings      TrainingRating[]

  @@index([status])
  @@index([type])
}

model TrainingSession {
  id              Int                   @id @default(autoincrement())
  trainingId      Int
  sessionDate     DateTime
  sessionEndDate  DateTime?
  durationMinutes Int
  modality        String
  location        String?
  meetingUrl      String?
  maxParticipants Int                   @default(0)
  waitlistEnabled Boolean               @default(true)
  notes           String?
  createdAt       DateTime              @default(now())
  training        Training              @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  participants    TrainingParticipant[]

  @@index([trainingId])
  @@index([sessionDate])
}

model TrainingParticipant {
  id                 Int             @id @default(autoincrement())
  sessionId          Int
  userId             Int
  trainingId         Int?
  status             String          @default("REGISTERED")
  finalScore         Float?
  attendedHours      Float?
  cancellationReason String?
  completedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  session            TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id])
  training           Training?       @relation(fields: [trainingId], references: [id])

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([status])
}

model TrainingRating {
  id         Int      @id @default(autoincrement())
  userId     Int
  trainingId Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  training   Training @relation(fields: [trainingId], references: [id])

  @@unique([userId, trainingId])
  @@index([trainingId])
}

// ══════════════════════════════════════════════════════════════════
// CONHECIMENTO
// ══════════════════════════════════════════════════════════════════

model KnowledgeCategory {
  id          Int                 @id @default(autoincrement())
  name        String
  slug        String              @unique
  description String?
  icon        String?
  color       String?
  parentId    Int?
  sortOrder   Int                 @default(0)
  parent      KnowledgeCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("CategoryHierarchy")
  articles    KnowledgeArticle[]

  @@index([parentId])
}

model KnowledgeArticle {
  id                     Int       @id @default(autoincrement())
  title                  String
  summary                String?
  content                String    @db.Text
  authorId               Int
  categoryId             Int?
  status                 String    @default("DRAFT")
  accessLevel            String    @default("PUBLIC")
  mandatory              Boolean   @default(false)
  readingMinutes         Int       @default(1)
  viewCount              Int       @default(0)
  avgRating              Float?
  restrictedDepartmentId Int?
  publishedAt            DateTime?
  expiresAt              DateTime?
  scheduledAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  author           User                     @relation(fields: [authorId], references: [id])
  category         KnowledgeCategory?       @relation(fields: [categoryId], references: [id])
  tags             KnowledgeTag[]
  interactions     KnowledgeInteraction[]
  ratings          ArticleRating[]
  comments         ArticleComment[]
  questions        ArticleQuestion[]
  versions         ArticleVersion[]
  acknowledgements ArticleAcknowledgement[]

  @@index([status])
  @@index([authorId])
  @@index([viewCount])
}

model KnowledgeTag {
  id        Int              @id @default(autoincrement())
  articleId Int
  name      String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model KnowledgeInteraction {
  id        Int              @id @default(autoincrement())
  userId    Int
  articleId Int
  action    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@index([articleId])
  @@index([userId])
}

model ArticleRating {
  id        Int              @id @default(autoincrement())
  userId    Int
  articleId Int
  score     Int
  comment   String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  article   KnowledgeArticle @relation(fields: [articleId], references: [id])

  @@unique([userId, articleId])
}

model ArticleComment {
  id        Int              @id @default(autoincrement())
  articleId Int
  authorId  Int
  content   String
  parentId  Int?
  createdAt DateTime         @default(now())
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id])
  parent    ArticleComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   ArticleComment[] @relation("CommentReplies")

  @@index([articleId])
}

model ArticleQuestion {
  id           Int              @id @default(autoincrement())
  articleId    Int
  askedById    Int
  question     String
  answer       String?
  answeredById Int?
  answeredAt   DateTime?
  createdAt    DateTime         @default(now())
  article      KnowledgeArticle @relation(fields: [articleId], references: [id])
  askedBy      User             @relation("QuestionAsker", fields: [askedById], references: [id])

  @@index([articleId])
}

model ArticleVersion {
  id           Int              @id @default(autoincrement())
  articleId    Int
  version      Int
  title        String
  content      String           @db.Text
  authorId     Int
  changeReason String?
  createdAt    DateTime         @default(now())
  article      KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author       User             @relation(fields: [authorId], references: [id])

  @@unique([articleId, version])
}

model ArticleAcknowledgement {
  id             Int              @id @default(autoincrement())
  userId         Int
  articleId      Int
  acknowledgedAt DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id])
  article        KnowledgeArticle @relation(fields: [articleId], references: [id])

  @@unique([userId, articleId])
}

model KnowledgeSearchLog {
  id           Int      @id @default(autoincrement())
  query        String
  userId       Int?
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([query])
  @@index([resultsCount])
}

// ══════════════════════════════════════════════════════════════════
// PROCESSOS
// ══════════════════════════════════════════════════════════════════

model ProcessStandard {
  id               Int       @id @default(autoincrement())
  code             String    @unique
  title            String
  description      String?
  objective        String?
  scope            String?
  version          String    @default("1.0")
  status           String    @default("DRAFT")
  riskLevel        String    @default("LOW")
  category         String?
  tags             String[]
  defaultSlaHours  Float?
  estimatedMinutes Float?
  nextReviewDate   DateTime?
  publishedAt      DateTime?
  ownerId          Int
  departmentId     Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  owner        User                 @relation(fields: [ownerId], references: [id])
  department   Department?          @relation(fields: [departmentId], references: [id])
  steps        ProcessStep[]
  instances    ProcessInstance[]
  versions     ProcessVersion[]
  approvalLogs ProcessApprovalLog[]
  @@index([status])
  @@index([category])
}

model ProcessStep {
  id               Int             @id @default(autoincrement())
  processId        Int
  type             String          @default("TASK")
  title            String
  description      String?
  order            Int
  responsibleId    Int?
  responsibleRole  String?
  slaHours         Float?
  estimatedMinutes Float?
  formSchema       String?
  exitConditions   String?
  requiresUpload   Boolean         @default(false)
  checklist        String[]
  process          ProcessStandard @relation(fields: [processId], references: [id], onDelete: Cascade)
  responsible      User?           @relation(fields: [responsibleId], references: [id])
  stepProgress     StepProgress[]
  @@index([processId])
}

model ProcessInstance {
  id             Int       @id @default(autoincrement())
  processId      Int
  processVersion String
  initiatedById  Int
  targetUserId   Int
  status         String    @default("IN_PROGRESS")
  notes          String?
  cancelReason   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  cancelledAt    DateTime?
  slaDeadline    DateTime?
  process      ProcessStandard @relation(fields: [processId], references: [id])
  initiatedBy  User            @relation("InstanceInitiator", fields: [initiatedById], references: [id])
  targetUser   User            @relation("InstanceTarget", fields: [targetUserId], references: [id])
  stepProgress StepProgress[]
  @@index([status])
  @@index([processId])
}

model StepProgress {
  id            Int       @id @default(autoincrement())
  instanceId    Int
  stepId        Int
  stepOrder     Int
  status        String    @default("WAITING")
  notes         String?
  formData      String?
  action        String?
  evidenceIds   Int[]
  completedById Int?
  startedAt     DateTime?
  completedAt   DateTime?
  slaDeadline   DateTime?
  duration      Int?

  instance    ProcessInstance @relation(fields: [instanceId], references: [id])
  step        ProcessStep     @relation(fields: [stepId], references: [id])
  completedBy User?           @relation(fields: [completedById], references: [id])

  @@unique([instanceId, stepId])
  @@index([status])
}

model ProcessVersion {
  id          Int             @id @default(autoincrement())
  processId   Int
  version     String
  snapshot    String
  createdById Int
  createdAt   DateTime        @default(now())
  process     ProcessStandard @relation(fields: [processId], references: [id])
}

model ProcessApprovalLog {
  id        Int             @id @default(autoincrement())
  processId Int
  userId    Int
  action    String
  comment   String?
  status    String
  createdAt DateTime        @default(now())
  process   ProcessStandard @relation(fields: [processId], references: [id])
  user      User            @relation(fields: [userId], references: [id])
}

model ProcessAuditLog {
  id         Int      @id @default(autoincrement())
  processId  Int?
  instanceId Int?
  userId     Int
  action     String
  meta       String?
  hash       String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([processId])
  @@index([instanceId])
}

// ══════════════════════════════════════════════════════════════════
// RH OPERACIONAL
// ══════════════════════════════════════════════════════════════════

model Payslip {
  id                     Int                @id @default(autoincrement())
  userId                 Int
  user                   User               @relation(fields: [userId], references: [id])
  period                 String                       // "2026-04"
  paymentDate            String?                      // "2026-04-25"
  baseSalary          Float    @default(0)
  mealAllowance       Float    @default(0)
  vacationAllowance   Float    @default(0)
  christmasAllowance  Float    @default(0)
  overtime            Float    @default(0)
  bonuses             Float    @default(0)
  otherAllowances     Float    @default(0)
  runId               Int?
  run                 PayrollRun?        @relation(fields: [runId], references: [id])
  countryCode         String             @default("AO")
  grossSalary         Float
  netSalary           Float    @default(0)
  totalEarnings       Float    @default(0)
  incomeTax           Float    @default(0)        // IRT
  socialSecurity      Float    @default(0)        // INSS 3% colaborador
  employerInss        Float    @default(0)        // INSS 8% empregador (informativo)
  healthInsurance     Float    @default(0)
  loanDeduction       Float    @default(0)
  advanceDeduction    Float    @default(0)
  otherDeductions     Float    @default(0)
  totalDeductions     Float    @default(0)
  totalEmployerCost      Float              @default(0)
  irtBracketRate      Float?
  irtFormula          String?
  irtOverride         Float?
  inssOverride        Float?
  taxBracket             String?
  status              String   @default("DRAFT")  // DRAFT | ISSUED | ACKNOWLEDGED | DISPUTED
  notes               String?
  issuedAt            DateTime?
  acknowledgedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById            Int?
  items                  PayslipItem[]
  accessLogs             PayslipAccessLog[]
  disputes               PayslipDispute[]
  @@unique([userId, period])
  @@index([userId, period])
  @@index([period, status])
  @@index([runId])
}

model PayslipItem {
  id        Int     @id @default(autoincrement())
  payslipId Int
  payslip   Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  code      String
  name      String
  type      String
  value     Float
  isTaxable Boolean @default(true)
  calcType  String?
  order     Int     @default(0)

  @@index([payslipId])
}

model PayslipAccessLog {
  id        Int      @id @default(autoincrement())
  payslipId Int
  payslip   Payslip  @relation(fields: [payslipId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  ipAddress String?
  createdAt DateTime @default(now())
  accessedAt  DateTime @default(now())
  @@index([payslipId])
  @@index([userId])
}

model PayslipDispute {
  id         Int       @id @default(autoincrement())
  payslipId  Int
  userId     Int
  reason     String
  details    String?
  status     String    @default("OPEN")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolution String?
  payslip    Payslip   @relation(fields: [payslipId], references: [id])
}

model CountryConfig {
  id                        Int          @id @default(autoincrement())
  countryCode               String
  name                      String
  currency                  String
  locale                    String
  taxYear                   Int
  minimumWage               Float
  defaultFoodAllowance      Float?
  defaultTransportAllowance Float?
  socialSecurity            Json
  healthInsuranceRate       Float?
  unionFeeRate              Float?
  guaranteeFundRate         Float?
  active                    Boolean      @default(true)
  irtBrackets               IrtBracket[]
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@unique([countryCode, taxYear])
  @@index([countryCode, active])
}

model IrtBracket {
  id        Int           @id @default(autoincrement())
  configId  Int
  config    CountryConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  min       Float
  max       Float?
  rate      Float
  deduction Float?
  order     Int           @default(0)

  @@index([configId])
}

model SalaryComponent {
  code        String            @id
  name        String
  description String?
  type        ComponentType
  calcType    ComponentCalcType
  fixedValue  Float?
  rate        Float?
  formula     String?
  isTaxable   Boolean           @default(true)
  isMandatory Boolean           @default(false)
  order       Int               @default(0)
  active      Boolean           @default(true)
  countryCode String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model EmployeeCompensation {
  id                 Int                             @id @default(autoincrement())
  userId             Int
  user               User                            @relation(fields: [userId], references: [id])
  baseSalary         Float
  countryCode        String?                         @default("AO")
  bankName           String?
  iban               String?
  accountNumber      String?
  effectiveFrom      DateTime                        @default(now())
  effectiveTo        DateTime?
  foodAllowance      Float?
  transportAllowance Float?
  components         EmployeeCompensationComponent[]
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@index([userId, effectiveFrom])
}

model EmployeeCompensationComponent {
  id             Int                  @id @default(autoincrement())
  compensationId Int
  compensation   EmployeeCompensation @relation(fields: [compensationId], references: [id], onDelete: Cascade)
  componentCode  String
  value          Float
  override       Boolean              @default(false)
}

model PayrollRun {
  id            Int              @id @default(autoincrement())
  period        String
  countryCode   String           @default("AO")
  status        PayrollRunStatus @default(DRAFT)
  notes         String?
  totalGross    Float?
  processedAt   DateTime?
  processedById Int?
  approvedAt    DateTime?
  approvedById  Int?
  createdById   Int
  createdBy     User             @relation("PayrollRunCreator", fields: [createdById], references: [id])
  payslips      Payslip[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([period, status])
}

model WorkDeclaration {
  id              Int       @id @default(autoincrement())
  userId          Int
  type            String
  status          String    @default("PENDING")
  purpose         String?   @db.Text
  addressedTo     String?
  content         String?   @db.Text
  referenceNumber String?   @unique
  generatedAt     DateTime?
  issuedAt        DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id])
}

model UserAttendance {
  id            Int      @id @default(autoincrement())
  userId        Int
  date          DateTime
  clockIn       String?
  clockOut      String?
  workMinutes   Int?
  status        String   @default("PRESENT")
  notes         String?  @db.Text
  justification String?  @db.Text
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ══════════════════════════════════════════════════════════════════
// ENGAGEMENT
// ══════════════════════════════════════════════════════════════════

model EngagementSurvey {
  id          Int              @id @default(autoincrement())
  title       String
  description String?          @db.Text
  status      String           @default("ACTIVE")
  endDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   SurveyQuestion[]
  responses   SurveyResponse[]

  @@index([status])
}

model SurveyQuestion {
  id       Int              @id @default(autoincrement())
  surveyId Int
  text     String           @db.Text
  type     String
  order    Int
  survey   EngagementSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers  SurveyAnswer[]

  @@index([surveyId])
}

model SurveyResponse {
  id        Int              @id @default(autoincrement())
  surveyId  Int
  userId    Int
  score     Float?
  createdAt DateTime         @default(now())
  survey    EngagementSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   SurveyAnswer[]

  @@index([surveyId])
  @@index([userId])
}

model SurveyAnswer {
  id         Int            @id @default(autoincrement())
  responseId Int
  questionId Int
  value      Int
  comment    String?        @db.Text
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
}

// ══════════════════════════════════════════════════════════════════
// GAMIFICAÇÃO
// ══════════════════════════════════════════════════════════════════

model UserPoints {
  id          Int          @id @default(autoincrement())
  userId      Int          @unique
  points      Int          @default(0)
  badgeAwards BadgeAward[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?      @db.Text
  awards      BadgeAward[]
}

model BadgeAward {
  id           Int         @id @default(autoincrement())
  userId       Int
  badgeId      Int
  awardedAt    DateTime    @default(now())
  userPointsId Int?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge        Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  userPoints   UserPoints? @relation(fields: [userPointsId], references: [id])

  @@index([userId])
  @@index([awardedAt])
}

// ══════════════════════════════════════════════════════════════════
// REPOSITÓRIO DE DOCUMENTOS
// ══════════════════════════════════════════════════════════════════

model DocCategoryModel {
  id                 Int             @id @default(autoincrement())
  name               String
  description        String?
  type               DocCategoryType
  retentionYears     Int?
  defaultSensitivity DocSensitivity  @default(INTERNAL)
  requiresApproval   Boolean         @default(false)
  active             Boolean         @default(true)
  documents          Document[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Document {
  id             Int               @id @default(autoincrement())
  title          String
  description    String?
  category       DocCategoryType
  categoryId     Int?
  docCategory    DocCategoryModel? @relation(fields: [categoryId], references: [id])
  sensitivity    DocSensitivity    @default(INTERNAL)
  status         DocStatus         @default(ACTIVE)
  origin         String            @default("UPLOAD")
  fileUrl        String
  mimeType       String
  fileSize       Int?
  fileName       String?
  version        String            @default("1.0")
  tags           String[]
  ocrText        String?
  ocrStatus      String?
  createdById    Int
  createdBy      User              @relation("DocCreator", fields: [createdById], references: [id])
  ownerId        Int?
  owner          User?             @relation("DocOwner", fields: [ownerId], references: [id])
  department     String?
  expiresAt      DateTime?
  retentionUntil DateTime?
  archivedAt     DateTime?
  archiveReason  String?
  deletedAt      DateTime?
  deleteReason   String?
  downloadCount  Int               @default(0)
  versions       DocVersion[]
  permissions    DocPermission[]
  shareLinks     DocShareLink[]
  downloads      DocDownload[]
  auditLogs      DocAuditLog[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([category, status])
  @@index([ownerId])
  @@index([department, status])
  @@index([expiresAt, status])
  @@index([sensitivity])
}

model DocVersion {
  id                Int      @id @default(autoincrement())
  documentId        Int
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber     Int
  fileUrl           String
  mimeType          String
  fileSize          Int?
  fileName          String?
  changeDescription String
  uploadedById      Int
  uploadedBy        User     @relation(fields: [uploadedById], references: [id])
  createdAt         DateTime @default(now())

  @@index([documentId, versionNumber])
}

model DocPermission {
  id          Int       @id @default(autoincrement())
  documentId  Int
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  department  String?
  permissions String[]
  expiresAt   DateTime?
  grantedById Int
  grantedBy   User      @relation("PermissionGrantor", fields: [grantedById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([documentId])
  @@index([userId])
}

model DocShareLink {
  id            Int             @id @default(autoincrement())
  documentId    Int
  document      Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token         String          @unique
  access        ShareLinkAccess
  expiresAt     DateTime
  passwordHash  String?
  maxDownloads  Int?
  downloadCount Int             @default(0)
  createdById   Int
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())

  @@index([token])
}

model DocDownload {
  id           Int      @id @default(autoincrement())
  documentId   Int
  document     Document @relation(fields: [documentId], references: [id])
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  downloadedAt DateTime @default(now())

  @@index([documentId])
  @@index([userId])
}

model DocAuditLog {
  id         Int      @id @default(autoincrement())
  documentId Int
  document   Document @relation(fields: [documentId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([userId])
}

// ══════════════════════════════════════════════════════════════════
// DOCUMENTOS CORPORATIVOS
// ══════════════════════════════════════════════════════════════════

model CompanyDocument {
  id            Int                @id @default(autoincrement())
  title         String
  description   String?            @db.Text
  category      DocCategoryType
  access        DocAccess
  fileUrl       String             @db.Text
  fileType      String
  fileSize      Int?
  version       String?
  tags          String[]
  downloadCount Int                @default(0)
  active        Boolean            @default(true)
  createdById   Int
  departmentId  Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  createdBy     User               @relation(fields: [createdById], references: [id])
  department    Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  downloads     DocumentDownload[]

  @@index([category])
  @@index([access])
  @@index([createdById])
  @@index([departmentId])
}

model DocumentDownload {
  id           Int             @id @default(autoincrement())
  documentId   Int
  userId       Int
  downloadedAt DateTime        @default(now())
  document     CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

// ══════════════════════════════════════════════════════════════════
// LIVE CLASSES
// ══════════════════════════════════════════════════════════════════

model LiveClass {
  id             Int                  @id @default(autoincrement())
  courseId       Int
  zoomMeetingId  String?              @db.Text
  topic          String               @db.Text
  scheduledAt    DateTime
  duration       Int
  recordingUrl   String?              @db.Text
  createdAt      DateTime             @default(now())
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances    LiveAttendance[]
  messages       LiveChatMessage[]
  postEvaluation PostClassEvaluation?

  @@index([courseId])
}

model LiveAttendance {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  joinedAt    DateTime
  leftAt      DateTime?
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, userId])
}

model LiveChatMessage {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  message     String    @db.Text
  createdAt   DateTime  @default(now())
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

model PostClassEvaluation {
  id           Int                 @id @default(autoincrement())
  liveClassId  Int                 @unique
  averageScore Float               @default(0)
  liveClass    LiveClass           @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  responses    PostClassResponse[]
}

model PostClassResponse {
  id           Int                 @id @default(autoincrement())
  evaluationId Int
  userId       Int
  rating       Int
  feedback     String?             @db.Text
  createdAt    DateTime            @default(now())
  evaluation   PostClassEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, userId])
}

// ══════════════════════════════════════════════════════════════════
// INSTRUTOR & MARKETPLACE
// ══════════════════════════════════════════════════════════════════

model InstructorProfile {
  id                    Int                 @id @default(autoincrement())
  userId                Int                 @unique
  bio                   String?             @db.Text
  expertiseArea         String
  instructorType        String              @default("STANDARD")
  specialties           String[]            @default([])
  certifications        String[]            @default([])
  linkedinUrl           String?
  hourlyRate            Float?
  availableForMentoring Boolean             @default(false)
  approved              Boolean             @default(false)
  ratingAverage         Float               @default(0)
  totalCourses          Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation(fields: [userId], references: [id])
  reviews               InstructorReview[]
  marketplaceCourses    MarketplaceCourse[]
  payouts               InstructorPayout[]
  cohorts               InstructorCohort[]
  courses               InstructorCourse[]

  @@index([approved])
  @@index([instructorType])
}

model InstructorCohort {
  id              Int                 @id @default(autoincrement())
  instructorId    Int
  courseId        Int
  name            String
  description     String?
  modalidade      String              @default("ONLINE")
  maxParticipants Int                 @default(30)
  status          String              @default("OPEN")
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  instructor      InstructorProfile   @relation(fields: [instructorId], references: [id])
  course          Course              @relation(fields: [courseId], references: [id])
  participants    CohortParticipant[]

  @@index([instructorId])
  @@index([status])
}

model CohortParticipant {
  id           Int              @id @default(autoincrement())
  cohortId     Int
  userId       Int
  status       String           @default("ACTIVE")
  progress     Int              @default(0)
  enrolledAt   DateTime         @default(now())
  lastActiveAt DateTime?
  cohort       InstructorCohort @relation(fields: [cohortId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
}

model InstructorCourse {
  id                  String            @id @default(uuid())
  instructorId        Int
  marketplaceCourseId String
  instructor          InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  marketplaceCourse   MarketplaceCourse @relation(fields: [marketplaceCourseId], references: [id], onDelete: Cascade)

  @@unique([instructorId, marketplaceCourseId])
}

model InstructorReview {
  id           Int               @id @default(autoincrement())
  instructorId Int
  userId       Int
  rating       Int
  comment      String            @db.Text
  createdAt    DateTime          @default(now())
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([instructorId, userId])
}

model InstructorPayout {
  id           String            @id @default(uuid())
  amount       Float
  createdAt    DateTime          @default(now())
  instructorId Int
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model MarketplaceCourse {
  id            String             @id @default(uuid())
  title         String
  price         Float
  createdAt     DateTime           @default(now())
  instructorId  Int
  instructor    InstructorProfile  @relation(fields: [instructorId], references: [id])
  courses       InstructorCourse[]
  description   String?
  category      String?
  level         String?
  workloadHours Int?
}

// ══════════════════════════════════════════════════════════════════
// NOTIFICAÇÕES & AUDITORIA
// ══════════════════════════════════════════════════════════════════

model NotificationLog {
  id          Int       @id @default(autoincrement())
  userId      Int
  type        String
  title       String?
  message     String    @db.Text
  priority    String    @default("MEDIUM")
  category    String?
  actionUrl   String?
  actionLabel String?
  metadata    String?
  read        Boolean   @default(false)
  readAt      DateTime?
  archived    Boolean   @default(false)
  success     Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
}

model NotificationPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  inApp              Boolean  @default(true)
  email              Boolean  @default(true)
  push               Boolean  @default(false)
  slack              Boolean  @default(false)
  sms                Boolean  @default(false)
  quietHourStart     Int      @default(22)
  quietHourEnd       Int      @default(8)
  digestFrequency    String   @default("NONE")
  disabledCategories String[] @default([])
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])
}

model NotificationTemplate {
  id                Int      @id @default(autoincrement())
  name              String
  eventType         String   @unique
  messageTemplate   String   @db.Text
  titleTemplate     String?
  priority          String   @default("MEDIUM")
  category          String?
  actionUrlTemplate String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([eventType])
  @@index([active])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action       String                          // CREATE|UPDATE|DELETE|LOGIN|EXPORT|SEND|READ|APPROVE|REJECT|DENIED|FAILED
  entity       String                          // ex: User, PDI, Course, Payslip
  entityId  Int?
  metadata     String?  @db.Text               // JSON extra
  hash         String?                         // SHA-256 deste registo
  previousHash String?                         // SHA-256 do registo anterior
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  entityName   String?
  before       String?
  after        String?
  changes      String?
  status       String   @default("SUCCESS")    // SUCCESS|FAILED|DENIED
  severity     String   @default("LOW")        // LOW|MEDIUM|HIGH|CRITICAL
  ip           String?
  userAgent    String?
  reason       String?
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model AutomationRule {
  id        Int      @id @default(autoincrement())
  name      String
  trigger   String
  action    String
  condition String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  tenantId      String
  description   String?
  triggerType   AutomationTrigger
  triggerConfigJson String // JSON com configuração do trigger (ex: { "eventType": "USER_HIRED" })
  conditionsJson  String? // JSON array de condições (ex: department, position)
  actionsJson     String  // JSON array de ações (ex: enroll_course, send_notification)
  priority      Int      @default(0) // ordem de execução
  isActive      Boolean  @default(true)
  runCount      Int      @default(0)
  lastRunAt     DateTime?
  lastRunStatus String?
  createdBy     String   // userId
  updatedAt     DateTime @updatedAt
  tenant     TenantConfig @relation(fields: [tenantId], references: [id])
  executions AutomationExecution[]
  @@map("automation_rules")
}

model AutomationExecution {
  id           String   @id @default(cuid())
  ruleId       Int
  triggeredBy  String?  // userId ou "SYSTEM"
  targetUserId String?
  status       String   // PENDING | RUNNING | SUCCESS | FAILED | SKIPPED
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  actionsLog   String?  // JSON com resultado de cada ação
  errorMessage String?
  rule AutomationRule @relation(fields: [ruleId], references: [id])
  @@map("automation_executions")
}

model SlaConfig {
  id              String   @id @default(cuid())
  tenantId        String
  name            String   // ex: "Uptime SLA - Enterprise"
  uptimePercent   Float    @default(99.5)  // 99.9 = "três noves"
  maxLatencyMs    Int      @default(2000)  // ms
  maxErrorRate    Float    @default(0.01)  // 1%
  incidentResponse Int     @default(60)   // minutos
  dataRetentionDays Int    @default(365)
  backupFrequency String   @default("DAILY")
  rpoMinutes      Int      @default(60)   // Recovery Point Objective
  rtoMinutes      Int      @default(240)  // Recovery Time Objective
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          TenantConfig @relation(fields: [tenantId], references: [id])
  @@map("sla_configs")
}

model ContentDeliveryConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  cdnProvider     String?  // CLOUDFRONT | AZURE_CDN | CLOUDFLARE
  cdnBaseUrl      String?
  adaptiveBitrate Boolean  @default(true)
  bitrateProfiles String?  // JSON: [{ label:"480p", bitrate:800 }, ...]
  offlineSyncEnabled Boolean @default(true)
  maxOfflineDays  Int      @default(30)
  compressionEnabled Boolean @default(true)
  maxVideoSizeMb  Int      @default(500)
  allowedFormats  String[] @default(["mp4","pdf","scorm","xapi"])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          TenantConfig @relation(fields: [tenantId], references: [id])
  @@map("content_delivery_configs")
}

model ScalabilityMetric {
  id                String   @id @default(cuid())
  tenantId          String?
  capturedAt        DateTime @default(now())
  activeUsers       Int      @default(0)
  concurrentSessions Int     @default(0)
  cpuUsagePercent   Float    @default(0)
  memoryUsagePercent Float   @default(0)
  diskUsagePercent  Float    @default(0)
  avgLatencyMs      Int      @default(0)
  p95LatencyMs      Int      @default(0)
  p99LatencyMs      Int      @default(0)
  requestsPerMinute Int      @default(0)
  errorRate         Float    @default(0)
  uptimePercent     Float    @default(100)
  storageUsedGb     Float    @default(0)
  bandwidthMbps     Float    @default(0)
  videoStreamCount  Int      @default(0)
  apiCallsPerMin    Int      @default(0)
  tenant TenantConfig? @relation(fields: [tenantId], references: [id])
  @@index([capturedAt])
  @@index([tenantId, capturedAt])
  @@map("scalability_metrics")
}

model SystemAlert {
  id           String   @id @default(cuid())
  tenantId     String?
  severity     AlertSeverity
  category     AlertCategory
  title        String
  message      String
  metricValue  Float?
  threshold    Float?
  isResolved   Boolean  @default(false)
  resolvedAt   DateTime?
  resolvedBy   String?  // userId
  notifiedVia  String[] @default([]) // ["EMAIL","SLACK","PUSH"]
  metadataJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant TenantConfig? @relation(fields: [tenantId], references: [id])
  @@index([severity, isResolved])
  @@index([tenantId, createdAt])
  @@map("system_alerts")
}

model HistoryRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String
  entityType  String
  entityId    Int?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
}



// ══════════════════════════════════════════════════════════════════
// INFRA / MOBILE / REPORTING
// ══════════════════════════════════════════════════════════════════

model MobileSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  deviceId  String
  platform  String
  lastLogin DateTime @default(now())
  pushToken String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MobileSyncLog {
  id       Int      @id @default(autoincrement())
  userId   Int
  syncedAt DateTime @default(now())
  entity   String
  status   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReportLog {
  id          Int      @id @default(autoincrement())
  type        String
  generatedBy Int
  fileUrl     String?  @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [generatedBy], references: [id])
}

model ExecutiveReport {
  id              Int               @id @default(autoincrement())
  title           String
  subtitle        String?
  type            String            @default("MONTHLY")
  status          String            @default("DRAFT")
  confidentiality String            @default("CONFIDENTIAL")
  generatedById   Int
  departmentId    Int?
  period          String?
  periodStart     DateTime?
  periodEnd       DateTime?
  achievements    String[]
  risks           String[]
  recommendations String[]
  nextSteps       String[]
  narrative       String?           @db.Text
  filePath        String
  format          ReportFormat
  approvedAt      DateTime?
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  generatedBy     User              @relation(fields: [generatedById], references: [id], onDelete: Cascade)
  department      Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  metrics         ExecutiveMetric[]
  approvals       ReportApproval[]
  accessLogs      ReportAccessLog[]

  @@index([generatedById])
  @@index([departmentId])
  @@index([status])
  @@index([type])
}

model ExecutiveMetric {
  id            Int             @id @default(autoincrement())
  reportId      Int
  label         String
  value         Float
  unit          String?
  previousValue Float?
  target        Float?
  status        String?
  comment       String?
  sortOrder     Int             @default(0)
  report        ExecutiveReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model ReportApproval {
  id         Int             @id @default(autoincrement())
  reportId   Int
  approverId Int
  decision   String
  comment    String?
  createdAt  DateTime        @default(now())
  report     ExecutiveReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  approver   User            @relation(fields: [approverId], references: [id])

  @@index([reportId])
}

model ReportAccessLog {
  id         Int             @id @default(autoincrement())
  reportId   Int
  userId     Int
  accessedAt DateTime        @default(now())
  report     ExecutiveReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id])

  @@index([reportId])
  @@index([userId])
}

model Organization {
  id        Int                 @id @default(autoincrement())
  name      String
  snapshots ExecutiveSnapshot[]
}

model ExecutiveSnapshot {
  id                   Int          @id @default(autoincrement())
  organizationId       Int
  totalUsers           Int
  totalEmployees       Int
  activeCourses        Int
  courseCompletionRate Float
  averagePerformance   Float
  engagementScore      Float
  roi                  Float
  createdAt            DateTime     @default(now())
  organization         Organization @relation(fields: [organizationId], references: [id])
}

model DashboardSnapshot {
  id                    Int         @id @default(autoincrement())
  departmentId          Int?
  totalUsers            Int
  totalCoursesCompleted Int
  averageScore          Float
  activePlans           Int
  generatedAt           DateTime    @default(now())
  department            Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([departmentId])
}

model IntegrationConfig {
  id             Int      @id @default(autoincrement())
  name           String
  endpoint       String
  config         Json
  apiKey         String?
  active         Boolean  @default(true)
  tenantId       String
  type           IntegrationType
  status         IntegrationStatus @default(INACTIVE)
  baseUrl        String?
  authType       String?  // OAUTH2 | API_KEY | BASIC | BEARER
  credentialsJson String? // criptografado — client_id, secret, token
  syncFrequency  SyncFrequency @default(DAILY)
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  webhookUrl     String?
  webhookEvents  String[] // ["course.completed", "user.promoted"]
  configJson     String?  // configurações extras específicas do tipo
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         TenantConfig @relation(fields: [tenantId], references: [id])
  syncLogs IntegrationSyncLog[]
  @@map("integration_configs")
}

model TenantConfig {
  id                String   @id @default(cuid())
  tenantCode        String   @unique // ex: "EMPRESA_XYZ"
  tenantName        String
  plan              TenantPlan @default(STARTER)
  maxUsers          Int      @default(100)
  maxStorageGb      Int      @default(50)
  isActive          Boolean  @default(true)
  trialEndsAt       DateTime?
  billingCycleStart DateTime?
  contractStartDate DateTime?
  contractEndDate   DateTime?
  customDomain      String?
  logoUrl           String?
  primaryColor      String?  @default("#1E40AF")
  defaultLanguage   String   @default("pt")
  defaultTimezone   String   @default("Africa/Luanda")
  defaultCurrency   String   @default("AOA")
  ssoEnabled        Boolean  @default(false)
  ssoProvider       SsoProvider?
  ssoConfigJson     String?  // JSON com configuração SSO (metadata, clientId, etc.)
  offlineModeEnabled Boolean @default(true)
  adaptiveBitrate   Boolean @default(true)
  cdnEnabled        Boolean @default(false)
  cdnConfigJson     String? // JSON com CDN config
  webhookSecret     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  integrations  IntegrationConfig[]
  slaConfigs    SlaConfig[]
  automationRules AutomationRule[]
  metrics       ScalabilityMetric[]
  alerts        SystemAlert[]
  contentDeliveryConfig ContentDeliveryConfig?
  declarations             Declaration[]
  declarationTenantConfigs DeclarationTenantConfig[]
  declarationTemplates     DeclarationTemplate[]
  @@map("tenant_configs")
}

model IntegrationSyncLog {
  id              String   @id @default(cuid())
  integrationId   Int
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  status          String   // SUCCESS | PARTIAL | FAILED
  recordsProcessed Int     @default(0)
  recordsFailed   Int      @default(0)
  errorMessage    String?
  detailsJson     String?  // JSON com detalhes de erros individuais
  integration IntegrationConfig @relation(fields: [integrationId], references: [id])
  @@map("integration_sync_logs")
}

model ApiIntegrationLog {
  id            Int      @id @default(autoincrement())
  integrationId Int
  status        String
  statusCode    Int?
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([integrationId])
}

model ScalabilitySnapshot {
  id                 Int      @id @default(autoincrement())
  totalUsers         Int
  activeUsers        Int
  totalEnrollments   Int
  totalCourses       Int
  totalLearningPaths Int
  createdAt          DateTime @default(now())
}

model GlobalSearchIndex {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  title       String
  description String?  @db.Text
  route       String?
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([title])
}

model OperationalMetric {
  id        Int      @id @default(autoincrement())
  unitId    Int
  metric    String
  value     Float
  createdAt DateTime @default(now())
  unit      Unit     @relation(fields: [unitId], references: [id])
}

model TrainingImpact {
  id           Int      @id @default(autoincrement())
  courseId     Int
  metric       String
  impactRate   Float
  calculatedAt DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
// AI & AVATAR
