model IntegrationConfig {
  id        Int      @id @default(autoincrement())
  name      String
  endpoint  String
  config    Json
  type      String
  baseUrl   String?  @db.Text
  apiKey    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

//////////////////////////
// ROLES & PERMISSIONS
//////////////////////////
model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?          @db.Text
  users           User[]
  permissions     Permission[]
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  action          String
  subject         String
  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@index([action])
  @@index([subject])
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
}

//////////////////////////
// MOBILE
//////////////////////////
model MobileSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  deviceId  String
  platform  String
  lastLogin DateTime @default(now())
  pushToken String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MobileSyncLog {
  id       Int      @id @default(autoincrement())
  userId   Int
  syncedAt DateTime @default(now())
  entity   String
  status   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////////
// REPORTING
//////////////////////////
model ExecutiveReport {
  id            Int               @id @default(autoincrement())
  title         String
  generatedById Int
  departmentId  Int?
  filePath      String
  format        ReportFormat
  createdAt     DateTime          @default(now())
  generatedBy   User              @relation(fields: [generatedById], references: [id], onDelete: Cascade)
  department    Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  metrics       ExecutiveMetric[]

  @@index([generatedById])
  @@index([departmentId])
}

model ExecutiveMetric {
  id       Int             @id @default(autoincrement())
  reportId Int
  label    String
  value    Float
  report   ExecutiveReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

enum ReportFormat {
  PDF
}

//////////////////////////
// AI
//////////////////////////
model AiTutorSession {
  id           Int         @id @default(autoincrement())
  userId       Int
  courseId     Int?
  enrollmentId Int?
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  messages     AiMessage[]

  @@index([userId])
  @@index([courseId])
}

model AiMessage {
  id         Int            @id @default(autoincrement())
  sessionId  Int
  role       AiRole
  content    String         @db.Text
  tokensUsed Int?
  createdAt  DateTime       @default(now())
  session    AiTutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
}

//////////////////////////
// INSTRUCTOR
//////////////////////////
model InstructorProfile {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique
  bio                String?             @db.Text
  expertiseArea      String              @db.Text
  approved           Boolean             @default(false)
  ratingAverage      Float               @default(0)
  totalCourses       Int                 @default(0)
  createdAt          DateTime            @default(now())
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews            InstructorReview[]
  payouts            InstructorPayout[]
  marketplaceCourses MarketplaceCourse[]
  // FIX: apenas uma relação para InstructorCourse — a duplicada foi removida
  courses            InstructorCourse[]
}

model InstructorCourse {
  id                  String            @id @default(uuid())
  instructorId        Int
  marketplaceCourseId String
  // FIX: única relação para InstructorProfile, sem colisão de FK
  instructor          InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  marketplaceCourse   MarketplaceCourse @relation(fields: [marketplaceCourseId], references: [id], onDelete: Cascade)

  @@unique([instructorId, marketplaceCourseId])
}

model InstructorReview {
  id           Int               @id @default(autoincrement())
  instructorId Int
  userId       Int
  rating       Int
  comment      String            @db.Text
  createdAt    DateTime          @default(now())
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([instructorId, userId])
}

model InstructorPayout {
  id           String            @id @default(uuid())
  amount       Float
  createdAt    DateTime          @default(now())
  instructorId Int
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model MarketplaceCourse {
  id           String             @id @default(uuid())
  title        String
  price        Float
  createdAt    DateTime           @default(now())
  instructorId Int
  instructor   InstructorProfile  @relation(fields: [instructorId], references: [id])
  courses      InstructorCourse[]
}

//////////////////////////
// EVENTS
//////////////////////////
model Event {
  id           Int                @id @default(autoincrement())
  title        String
  description  String?            @db.Text
  startAt      DateTime
  endAt        DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  organizerId  Int
  location     String?
  organizer    User               @relation(fields: [organizerId], references: [id])
  participants EventParticipant[]
}

model EventParticipant {
  id      Int         @id @default(autoincrement())
  eventId Int
  userId  Int
  status  EventStatus @default(PENDING)
  event   Event       @relation(fields: [eventId], references: [id])
  user    User        @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

enum EventStatus {
  PENDING
  CONFIRMED
  CANCELED
}
