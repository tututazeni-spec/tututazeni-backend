model AiMessage {
  id             Int            @id @default(autoincrement())
  sessionId      Int
  role           String
  content        String         @db.Text
  tokensUsed     Int?
  latencyMs      Int?
  provider       String?
  model          String?
  rating         Int?
  ratingFeedback String?
  agentAction    String?
  createdAt      DateTime       @default(now())
  session        AiTutorSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([role])
