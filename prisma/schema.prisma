model AiTutorMemory {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  summary   String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AvatarScript {
  id        Int      @id @default(autoincrement())
  title     String
  script    String   @db.Text
  version   Int      @default(1)
  videoUrl  String?  @db.Text
  createdAt DateTime @default(now())
}

model ContentAsset {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  type        String
  url         String   @db.Text
  version     Int      @default(1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AvatarScenario {
  id           Int             @id @default(autoincrement())
  title        String
  description  String?         @db.Text
  difficulty   Int             @default(1)
  competencyId Int?
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  competency   Competency?     @relation(fields: [competencyId], references: [id], onDelete: SetNull)
  sessions     AvatarSession[]

  @@index([competencyId])
}

model AvatarSession {
  id          Int            @id @default(autoincrement())
  userId      Int
  scenarioId  Int
  status      String         @default("IN_PROGRESS")
  score       Float?
  feedback    String?        @db.Text
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario    AvatarScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
}

// ══════════════════════════════════════════════════════════════════
// EVENTOS
// ══════════════════════════════════════════════════════════════════

model Event {
  id                   Int                @id @default(autoincrement())
  title                String
  description          String?            @db.Text
  type                 String             @default("TRAINING")
  modalidade           String             @default("ONLINE")
  status               String             @default("DRAFT")
  startAt              DateTime
  endAt                DateTime
  location             String?
  meetingUrl           String?
  meetingPassword      String?
  maxCapacity          Int                @default(50)
  waitlistEnabled      Boolean            @default(true)
  certificateEnabled   Boolean            @default(false)
  minAttendancePercent Int                @default(80)
  tags                 String[]           @default([])
  mandatory            Boolean            @default(false)
  bannerUrl            String?
  courseId             Int?
  organizerId          Int
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organizer            User               @relation(fields: [organizerId], references: [id])
  participants         EventParticipant[]
  feedbacks            EventFeedback[]
  certificates         Certificate[]

  @@index([organizerId])
  @@index([status])
  @@index([type])
  @@index([startAt])
}

model EventParticipant {
  id           Int       @id @default(autoincrement())
  eventId      Int
  userId       Int
  status       String    @default("PENDING")
  note         String?
  registeredAt DateTime  @default(now())
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model EventFeedback {
  id               Int      @id @default(autoincrement())
  eventId          Int
  userId           Int
  nps              Int
  rating           Int?
  instructorRating Int?
  comment          String?  @db.Text
  createdAt        DateTime @default(now())
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
}

// ══════════════════════════════════════════════════════════════════
// ATTENDANCE — Controle de Presenças
// ══════════════════════════════════════════════════════════════════

model Attendance {
  id              Int                       @id @default(autoincrement())
  employeeId      Int
  employee        Employee                  @relation(fields: [employeeId], references: [id])
  date            DateTime
  status          AttendanceStatus          @default(PRESENT)
  context         AttendanceContext         @default(WORK)
  method          CheckInMethod             @default(MANUAL)
  clockIn         String?
  clockOut        String?
  clockInAt       DateTime?
  clockOutAt      DateTime?
  breakMinutes    Int?                      @default(0)
  workMinutes     Int?                      @default(0)
  hoursWorked     Float?                    @default(0)
  overtimeMinutes Int?                      @default(0)
  presencePercent Float?
  latitude        Float?
  longitude       Float?
  locationLabel   String?
  deviceInfo      String?
  ipAddress       String?
  selfieUrl       String?
  facialValidated Boolean                   @default(false)
  eventId         Int?
  courseId        Int?
  sessionId       Int?
  leaveRequestId  Int?
  justification   String?
  notes           String?
  shiftId         Int?
  justifications  AttendanceJustification[]
  adjustments     AttendanceAdjustment[]
  overtimeRecords OvertimeRecord[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([employeeId, date, context])
  @@index([employeeId, date])
  @@index([date, status])
  @@index([eventId])
  @@index([courseId])
}

model LeaveRequest {
  id              Int                 @id @default(autoincrement())
  userId          Int
  user            User                @relation(fields: [userId], references: [id])
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  durationMode    DurationMode        @default(FULL_DAY)
  hours           Float?
  workDays        Float               @default(0)
  calendarDays    Int                 @default(0)
  reason          String?
  status          LeaveStatus         @default(PENDING)
  attachments     String[]
  substituteId    Int?
  finalApprovedAt DateTime?
  approvals       LeaveApproval[]
  documents       LeaveDocument[]
  impactPreview   LeaveImpactPreview?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  leaveTypeCode  String?
  reviewNotes    String?
  reviewedById   Int?
  reviewedAt     DateTime?
  halfDay        Boolean   @default(false)
  halfDayPeriod  String?
  @@index([userId, status])
  @@index([startDate, endDate])
}

model LeaveApproval {
  id         Int          @id @default(autoincrement())
  requestId  Int
  request    LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId Int
  approver   User         @relation(fields: [approverId], references: [id])
  level      Int          @default(1)
  decision   String?
  notes      String?
  decidedAt  DateTime?
  createdAt  DateTime     @default(now())

  @@index([requestId])
  @@index([approverId, decidedAt])
}

model LeaveBalance {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  leaveType LeaveType
  balance   Float     @default(0)
  used      Float     @default(0)
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt
  @@unique([userId, leaveType])
}

model LeaveBalanceHistory {
  id            Int       @id @default(autoincrement())
  userId        Int
  leaveType     LeaveType
  balanceBefore Float
  balanceAfter  Float
  change        Float
  reason        String
  requestId     Int?
  updatedById   Int
  createdAt     DateTime  @default(now())
  leaveTypeCode  String?
  @@index([userId, leaveType])
}

model LeaveDocument {
  id           Int          @id @default(autoincrement())
  requestId    Int
  request      LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  name         String
  fileUrl      String
  mimeType     String?
  uploadedById Int
  createdAt    DateTime     @default(now())
}

model LeaveImpactPreview {
  id              Int          @id @default(autoincrement())
  requestId       Int          @unique
  request         LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  affectedCourses Int          @default(0)
  affectedEvents  Int          @default(0)
  notes           String?
  createdAt       DateTime     @default(now())
}

model LeaveTypeConfig {
  id                   Int      @id @default(autoincrement())
  code                 String   @unique
  name                 String
  description          String?
  color                String?
  icon                 String?
  isPaid               Boolean  @default(true)
  annualLimit          Int?
  allowCarryOver       Boolean  @default(false)
  carryOverLimit       Int?
  countWorkDaysOnly    Boolean  @default(true)
  autoApprove          Boolean  @default(false)
  autoApproveUnderDays Int?
  minNoticeDays        Int?
  maxConsecutiveDays   Int?
  active               Boolean  @default(true)
  category             String?
  createdAt            DateTime @default(now()) 
  @@map("leave_type_configs")
}
 
model LeavePolicy {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  department        String?
  seniority         String?
  approvalLevels    Int      @default(1)
  maxAbsencePercent Int      @default(30)
  blackoutPeriods   Json?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  @@map("leave_policies")
}

model AttendanceJustification {
  id           Int        @id @default(autoincrement())
  attendanceId Int
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  reason       String
  attachments  String[]
  leaveType    LeaveType?
  status       String     @default("PENDING")
  reviewNotes  String?
  reviewedById Int?
  reviewedAt   DateTime?
  createdAt    DateTime   @default(now())
  recordId     Int?
  record       AttendanceRecord? @relation("RecordJustifications", fields: [recordId], references: [id])
  @@index([attendanceId])
  @@index([status])
}

model AttendanceRecord {
  id              Int       @id @default(autoincrement())
  userId          Int
  date            DateTime
  status          String    @default("PRESENT")
  context         String    @default("WORK")
  method          String    @default("MANUAL")
  clockIn         String?
  clockOut        String?
  clockInAt       DateTime?
  clockOutAt      DateTime?
  breakMinutes    Int?      @default(0)
  workMinutes     Int?      @default(0)
  hoursWorked     Float?    @default(0)
  overtimeMinutes Int?      @default(0)
  presencePercent Float?
  latitude        Float?
  longitude       Float?
  locationLabel   String?
  deviceInfo      String?
  ipAddress       String?
  selfieUrl       String?
  facialValidated Boolean   @default(false)
  eventId         Int?
  courseId        Int?
  sessionId       Int?
  leaveRequestId  Int?
  justification   String?
  notes           String?
  shiftId         Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation("UserAttendanceRecords", fields: [userId], references: [id])
  justifications  AttendanceJustification[] @relation("RecordJustifications")
  adjustments     AttendanceAdjustment[]    @relation("RecordAdjustments")
  @@unique([userId, date, context])
  @@index([userId, date])
  @@index([date, status])
  @@map("attendance_records")
}

model AttendanceAdjustment {
  id           Int        @id @default(autoincrement())
  attendanceId Int
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  adjustedById Int
  adjustedBy   User       @relation(fields: [adjustedById], references: [id])
  changes      Json
  reason       String
  createdAt    DateTime   @default(now())
  recordId     Int?
  record       AttendanceRecord? @relation("RecordAdjustments", fields: [recordId], references: [id])
  @@index([attendanceId])
}

model WorkSchedule {
  id                 Int            @id @default(autoincrement())
  name               String         @unique
  description        String?
  shiftType          ShiftType
  startTime          String
  endTime            String
  breakMinutes       Int?           @default(60)
  toleranceMinutes   Int?           @default(10)
  minPresencePercent Float?         @default(75)
  workDays           Int[]
  userSchedules      UserSchedule[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model UserSchedule {
  id            Int          @id @default(autoincrement())
  userId        Int          @unique
  user          User         @relation(fields: [userId], references: [id])
  scheduleId    Int
  schedule      WorkSchedule @relation(fields: [scheduleId], references: [id])
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())

  @@index([userId])
}

model OvertimeRecord {
  id                 Int            @id @default(autoincrement())
  userId             Int
  user               User           @relation(fields: [userId], references: [id])
  date               DateTime
  overtimeMinutes    Int
  reason             String
  compensateWithTime Boolean        @default(true)
  compensated        Boolean        @default(false)
  status             OvertimeStatus @default(PENDING)
  reviewNotes        String?
  reviewedById       Int?
  reviewedAt         DateTime?
  attendanceId       Int?
  attendance         Attendance?    @relation(fields: [attendanceId], references: [id])
  createdAt          DateTime       @default(now())

  @@index([userId, status])
}

model AllowedLocation {
  id           Int      @id @default(autoincrement())
  name         String
  latitude     Float
  longitude    Float
  radiusMeters Float    @default(200)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════════
// LEGACY — Employee-based
// ══════════════════════════════════════════════════════════════════

model Employee {
  id               Int                   @id @default(autoincrement())
  matricula        String?               @unique
  name             String
  email            String                @unique
  phone            String?
  avatarUrl        String?
  cpf              String?               @unique
  rg               String?
  birthDate        DateTime?
  gender           Gender?
  maritalStatus    String?
  nationality      String?
  address          Json?
  emergencyContact Json?
  role             String
  jobTitle         String?
  department       String?
  area             String?
  team             String?
  unit             String?
  location         String?
  seniority        SeniorityLevel?
  contractType     ContractType?
  workMode         WorkMode?
  status           EmployeeStatus        @default(ACTIVE)
  joinedAt         DateTime
  costCenter       String?
  salary           Float?
  salaryBand       String?
  managerId        Int?
  manager          Employee?             @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates     Employee[]            @relation("ManagerSubordinates")
  contracts        Contract[]
  evaluations      Evaluation[]
  feedbacks        Feedback360[]
  careerPlans      CareerPlan[]
  pdis             LegacyPdi[]
  attendances      Attendance[]
  documents        EmployeeDocument[]
  employeeSkills   LegacyEmployeeSkill[]
  newSkills        EmployeeSkill[]       @relation("EmployeeSkills")
  assessedSkills   EmployeeSkill[]       @relation("SkillAssessor")
  timeline         EmployeeTimeline[]
  requests         SelfServiceRequest[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([department, status])
  @@index([managerId])
  @@index([status, joinedAt])
}

model EmployeeSkill {
  id         Int       @id @default(autoincrement())
  employeeId Int
  assessorId Int?
  skillName  String
  level      Int?
  createdAt  DateTime  @default(now())
  employee   Employee  @relation("EmployeeSkills", fields: [employeeId], references: [id])
  assessor   Employee? @relation("SkillAssessor", fields: [assessorId], references: [id])
  skillId      Int?
  currentLevel Int?
  desiredLevel Int?
  source       String?
  notes        String?
  assessedAt   DateTime?
  updatedAt    DateTime  @updatedAt
  skill        Skill?    @relation("EmployeeSkillRef", fields: [skillId], references: [id])
  @@unique([employeeId, skillId])
}

model Contract {
  id         Int          @id @default(autoincrement())
  employeeId Int
  employee   Employee     @relation(fields: [employeeId], references: [id])
  type       ContractType
  startDate  DateTime
  endDate    DateTime?
  status     String
  salary     Float?
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Feedback360 {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])
  evaluatorId   Int
  evaluatorRole String
  score         Float
  strengths     String?
  improvements  String?
  comments      String
  cycle         String?
  anonymous     Boolean  @default(false)
  evaluatedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([employeeId, cycle])
}

model CareerPlan {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id])
  title           String
  description     String
  targetRole      String?
  startDate       DateTime
  endDate         DateTime
  progressPercent Int      @default(0)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LegacyPdi {
  id              Int               @id @default(autoincrement())
  employeeId      Int
  employee        Employee          @relation(fields: [employeeId], references: [id])
  title           String
  objective       String?
  startDate       DateTime
  endDate         DateTime
  progressPercent Int               @default(0)
  status          String            @default("ACTIVE")
  notes           String?
  actions         LegacyPdiAction[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([employeeId])
  @@index([status])
}

model LegacyPdiAction {
  id           Int       @id @default(autoincrement())
  pdiId        Int
  pdi          LegacyPdi @relation(fields: [pdiId], references: [id], onDelete: Cascade)
  description  String
  deadline     DateTime
  done         Boolean   @default(false)
  resourceType String?
  resourceUrl  String?
  createdAt    DateTime  @default(now())
}

model EmployeeDocument {
  id                Int       @id @default(autoincrement())
  employeeId        Int
  employee          Employee  @relation(fields: [employeeId], references: [id])
  name              String
  type              String
  fileUrl           String
  mimeType          String?
  fileSize          Int?
  expiresAt         DateTime?
  requiresSignature Boolean   @default(false)
  signedAt          DateTime?
  status            String    @default("ACTIVE")
  uploadedById      Int
  deletedAt         DateTime?
  deletedById       Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId, status])
}

model EmployeeTimeline {
  id          Int               @id @default(autoincrement())
  employeeId  Int
  employee    Employee          @relation(fields: [employeeId], references: [id])
  type        TimelineEventType
  title       String
  description String?
  metadata    Json?
  isPublic    Boolean           @default(true)
  occurredAt  DateTime          @default(now())
  createdAt   DateTime          @default(now())

  @@index([employeeId, occurredAt])
}

model SelfServiceRequest {
  id           Int           @id @default(autoincrement())
  employeeId   Int
  employee     Employee      @relation(fields: [employeeId], references: [id])
  type         RequestType
  reason       String
  payload      Json?
  attachments  String[]
  status       RequestStatus @default(PENDING)
  reviewNotes  String?
  reviewedById Int?
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([employeeId, status])
}

model Evaluation {
  id                 Int                  @id @default(autoincrement())
  courseId           Int
  title              String
  question           String               @db.Text
  options            Json
  correctOptionIndex Int
  employeeId         Int
  score              Float
  feedback           String               @db.Text
  evaluatedAt        DateTime
  createdAt          DateTime             @default(now())
  employee           Employee             @relation(fields: [employeeId], references: [id])
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts           EvaluationAttempt[]
  questions          EvaluationQuestion[]

  @@index([courseId])
}

model EvaluationQuestion {
  id           Int                       @id @default(autoincrement())
  evaluationId Int
  question     String                    @db.Text
  options      Json
  correctIndex Int
  evaluation   Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  answers      EvaluationAttemptAnswer[]

  @@index([evaluationId])
}

model EvaluationAttempt {
  id             Int                       @id @default(autoincrement())
  enrollmentId   Int
  validationCode String
  scorePercent   Float?
  passed         Boolean?
  attemptedAt    DateTime                  @default(now())
  startedAt      DateTime                  @default(now())
  finishedAt     DateTime?
  evaluationId   Int
  enrollment     Enrollment                @relation("EnrollmentAttempts", fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluation     Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  answers        EvaluationAttemptAnswer[]

  @@index([evaluationId])
  @@index([enrollmentId])
}

model EvaluationAttemptAnswer {
  id            Int                @id @default(autoincrement())
  attemptId     Int
  questionId    Int
  selectedIndex Int
  isCorrect     Boolean
  createdAt     DateTime           @default(now())
  attempt       EvaluationAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      EvaluationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

model SkillCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  family      String?
  domain      String?
  active      Boolean  @default(true)
  skills      Skill[]
  createdAt   DateTime @default(now())

  @@index([family, domain])
}

model Skill {
  id                Int                      @id @default(autoincrement())
  name              String                   @unique
  description       String?
  type              SkillType
  categoryId        Int?
  category          SkillCategory?           @relation(fields: [categoryId], references: [id])
  tags              String[]
  strategicWeight   Float?                   @default(1.0)
  maxLevel          Int                      @default(5)
  active            Boolean                  @default(true)
  proficiencyLevels SkillProficiencyLevel[]
  employeeSkills    LegacyEmployeeSkill[]
  roleRequirements  RoleSkillRequirement[]
  assessmentHistory SkillAssessmentHistory[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  employeeSkills2   EmployeeSkill[]  @relation("EmployeeSkillRef")
  @@index([type, active])
}

model SkillProficiencyLevel {
  id                 Int    @id @default(autoincrement())
  skillId            Int
  skill              Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level              Int
  name               String
  description        String
  observableBehavior String
  expectedMonths     Int?

  @@unique([skillId, level])
  @@index([skillId])
}

model RoleSkillMatrix {
  id           Int                    @id @default(autoincrement())
  roleCode     String                 @unique
  department   String?
  requirements RoleSkillRequirement[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model RoleSkillRequirement {
  id            Int             @id @default(autoincrement())
  matrixId      Int
  roleMatrix    RoleSkillMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  skillId       Int
  skill         Skill           @relation(fields: [skillId], references: [id])
  careerRoleId  Int?
  careerRole    CareerRole?     @relation(fields: [careerRoleId], references: [id])
  requiredLevel Int
  weight        Float           @default(1.0)
  mandatory     Boolean         @default(true)

  @@unique([matrixId, skillId])
  @@index([matrixId])
}

model LegacyEmployeeSkill {
  id               Int              @id @default(autoincrement())
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  employeeId       Int?
  employee         Employee?        @relation(fields: [employeeId], references: [id])
  skillId          Int
  skill            Skill            @relation(fields: [skillId], references: [id])
  currentLevel     Int
  targetLevel      Int?
  source           AssessmentSource @default(SELF)
  assessedById     Int?
  assessedBy       User?            @relation("SkillAssessor", fields: [assessedById], references: [id])
  managerValidated Boolean          @default(false)
  notes            String?
  evidenceUrl      String?
  assessedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

model SkillAssessmentHistory {
  id           Int              @id @default(autoincrement())
  userId       Int
  skillId      Int
  skill        Skill            @relation(fields: [skillId], references: [id])
  level        Int
  source       AssessmentSource
  assessedById Int?
  notes        String?
  snapshotAt   DateTime

  @@index([userId, skillId, snapshotAt])
}

// ══════════════════════════════════════════════════════════════════
// MISC
// ══════════════════════════════════════════════════════════════════

model Post {
  id         Int        @id @default(autoincrement())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  title      String     @db.Text
  published  Boolean    @default(false)
  categories Category[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

// ══════════════════════════════════════════════════════════════════
// DECLARAÇÃO DE TRABALHO
// ══════════════════════════════════════════════════════════════════

model Declaration {
  id              String            @id @default(cuid())
  tenantId        String
  code            String            @unique // código legível único ex: INNOVA-2024-000123
  templateId  Int
  requestedById  Int            // colaborador que solicitou
  assignedToId   Int?           // RH responsável
  employeeId     Int            // colaborador referenciado na declaração
  type            DeclarationType
  status          DeclarationStatus @default(DRAFT)
  locale          DeclarationLocale @default(PT)
  layout          DocumentLayout    @default(FORMAL)
  
  // Conteúdo gerado
  renderedContent String?           @db.Text  // HTML renderizado com dados reais
  pdfUrl          String?
  docxUrl         String?
  
  // Dados do colaborador no momento da emissão (snapshot)
  employeeSnapshot Json             // nome, cargo, departamento, admissão, etc.
  
  // Metadados do documento
  title           String
  purpose         String?           // finalidade específica (bancária, acadêmica, etc.)
  showSalary      Boolean           @default(false)
  watermark       Boolean           @default(false)
  expiresAt       DateTime?
  issuedAt        DateTime?
  revokedAt       DateTime?
  revokedReason   String?

  // Verificação
  verificationHash String?          @unique  // SHA256 do conteúdo final
  qrCodeUrl       String?

  // Controle
  requestNotes    String?
  internalNotes   String?
  rejectedReason  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant TenantConfig @relation(fields: [tenantId], references: [id])
  template    DeclarationTemplate @relation(fields: [templateId], references: [id])
  requestedBy User                @relation("DeclarationRequestedBy", fields: [requestedById], references: [id])
  assignedTo  User?               @relation("DeclarationAssignedTo", fields: [assignedToId], references: [id])
  employee    User                @relation("DeclarationEmployee", fields: [employeeId], references: [id])
  signatures  DeclarationSignature[]
  auditLogs   DeclarationAuditLog[]
  accessLogs  DeclarationAccessLog[]
  attachments DeclarationAttachment[]
  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@index([tenantId, requestedById])
  @@index([code])
  @@map("declarations")
}

model DeclarationSignature {
  id              String        @id @default(cuid())
  declarationId   String
  signerId       Int
  signerRole      String        // "RH", "MANAGER", "DIRECTOR"
  type            SignatureType @default(IMAGE_UPLOAD)
  signatureUrl    String?       // URL da imagem da assinatura
  certificateData Json?         // dados do certificado digital, se aplicável
  signedAt        DateTime      @default(now())
  ipAddress       String?
  userAgent       String?
  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  signer      User        @relation(fields: [signerId], references: [id])
  @@unique([declarationId, signerId])
  @@map("declaration_signatures")
}

model DeclarationAuditLog {
  id            String   @id @default(cuid())
  declarationId String
  actorId        Int
  action        String   // CREATED, UPDATED, STATUS_CHANGED, SIGNED, EXPORTED, REVOKED, etc.
  fromStatus    DeclarationStatus?
  toStatus      DeclarationStatus?
  details       Json?
  ipAddress     String?
  timestamp     DateTime @default(now())
  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  actor       User        @relation(fields: [actorId], references: [id])
  @@index([declarationId])
  @@index([actorId])
  @@map("declaration_audit_logs")
}

model DeclarationAccessLog {
  id            String   @id @default(cuid())
  declarationId String
  accessedVia   String   // "QR_CODE", "DIRECT_LINK", "EMAIL_LINK"
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())
  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  @@index([declarationId])
  @@map("declaration_access_logs")
}

model DeclarationAttachment {
  id            String   @id @default(cuid())
  declarationId String
  uploadedById   Int
  name          String
  url           String
  mimeType      String
  sizeBytes     Int
  uploadedAt    DateTime @default(now())
  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  uploadedBy  User        @relation(fields: [uploadedById], references: [id])
  @@map("declaration_attachments")
}

model DeclarationTenantConfig {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  logoUrl         String?
  companyName     String?
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  companyNif      String?
  headerHtml      String? @db.Text
  footerHtml      String? @db.Text
  defaultLayout   DocumentLayout @default(FORMAL)
  defaultLocale   DeclarationLocale @default(PT)
  defaultValidity Int?    // dias padrão de validade
  allowSalaryExposure Boolean @default(false)
  requireManagerSignature Boolean @default(false)
  emailNotifications Boolean @default(true)
  updatedAt DateTime @updatedAt
  tenant TenantConfig @relation(fields: [tenantId], references: [id])
  @@map("declaration_tenant_configs")
}


model DeclarationPurpose {
  id               Int                   @id @default(autoincrement())
  name             String
  description      String?
  category         PurposeCategory
  requiresApproval Boolean               @default(false)
  active           Boolean               @default(true)
  templates        DeclarationTemplate[]
  requests         DeclarationRequest[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model DeclarationTemplate {
  id               Int                  @id @default(autoincrement())
  name             String
  description      String?
  purposeId        Int?
  tenantId         String
  tenant TenantConfig @relation(fields: [tenantId], references: [id])
  type            DeclarationType
  locale          DeclarationLocale @default(PT)
  layout          DocumentLayout  @default(FORMAL)
  purpose          DeclarationPurpose?  @relation(fields: [purposeId], references: [id])
  language         TemplateLanguage     @default(PT)
  content          String
  variables        String[]
  bodyContent     String          @db.Text   // HTML com variáveis {{variavel}}
  isActive        Boolean         @default(true)
  isDefault       Boolean         @default(false)
  validityDays    Int?            // null = sem expiração
  requiredFields  String[]        // campos obrigatórios para este template
  customVariables Json?           // variáveis personalizadas além das padrão
  requiresApproval Boolean              @default(true)
  autoGenerate     Boolean              @default(false)
  validDays        Int?
  version          Int                  @default(1)
  active           Boolean              @default(true)
  createdById      Int
  createdBy        User                 @relation(fields: [createdById], references: [id])
  updatedBy        User?                @relation("TemplateUpdatedBy", fields: [updatedById], references: [id])
  declarations     Declaration[]
  requests         DeclarationRequest[]
  updatedById    Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([purposeId, tenantId, type, isActive])
  @@map("declaration_templates")
}

model DeclarationRequest {
  id               Int                   @id @default(autoincrement())
  userId           Int
  user             User                  @relation(fields: [userId], references: [id])
  templateId       Int
  template         DeclarationTemplate   @relation(fields: [templateId], references: [id])
  purposeId        Int?
  purpose          DeclarationPurpose?   @relation(fields: [purposeId], references: [id])
  language         TemplateLanguage      @default(PT)
  addressedTo      String?
  observations     String?
  extraVariables   Json?
  status           DocumentRequestStatus @default(PENDING)
  generatedContent String?
  referenceNumber  String?               @unique
  verificationCode String?               @unique
  generatedAt      DateTime?
  issuedAt         DateTime?
  expiresAt        DateTime?
  approval         DeclarationApproval?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, status])
  @@index([verificationCode])
}

model DeclarationApproval {
  id         Int                @id @default(autoincrement())
  requestId  Int                @unique
  request    DeclarationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewerId Int
  reviewer   User               @relation(fields: [reviewerId], references: [id])
  approved   Boolean
  notes      String?
  reviewedAt DateTime
  createdAt  DateTime           @default(now())
}

model WorkDeclForm {
  id                       Int                  @id @default(autoincrement())
  title                    String
  description              String?
  type                     WorkDeclType
  periodicity              String?
  validFrom                DateTime
  validTo                  DateTime?
  mandatory                Boolean              @default(false)
  requiresDigitalSignature Boolean              @default(false)
  active                   Boolean              @default(true)
  targetAllEmployees       Boolean              @default(true)
  targetDepartments        String[]
  targetRoles              String[]
  createdById              Int
  createdBy                User                 @relation(fields: [createdById], references: [id])
  questions                WorkDeclQuestion[]
  submissions              WorkDeclSubmission[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([type, active])
}

model WorkDeclQuestion {
  id                Int              @id @default(autoincrement())
  formId            Int
  form              WorkDeclForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  key               String
  label             String
  helpText          String?
  fieldType         String
  required          Boolean          @default(false)
  options           String[]
  conditionalKey    String?
  conditionalValue  String?
  order             Int              @default(0)
  placeholder       String?
  validationRegex   String?
  acceptedFileTypes String[]
  answers           WorkDeclAnswer[]

  @@unique([formId, key])
  @@index([formId])
}

model WorkDeclSubmission {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  formId          Int
  form            WorkDeclForm     @relation(fields: [formId], references: [id])
  status          WorkDeclStatus   @default(PENDING)
  signature       String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  exemptionReason String?
  answers         WorkDeclAnswer[]
  review          WorkDeclReview?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, formId])
  @@index([userId, status])
  @@index([formId, status])
}

model WorkDeclAnswer {
  user         User?              @relation(fields: [userId], references: [id])
  userId       Int?
  id           Int                @id @default(autoincrement())
  submissionId Int
  submission   WorkDeclSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   Int?
  question     WorkDeclQuestion?  @relation(fields: [questionId], references: [id])
  questionKey  String
  value        String
  createdAt    DateTime           @default(now())

  @@index([submissionId])
}

model WorkDeclReview {
  id               Int                @id @default(autoincrement())
  submissionId     Int                @unique
  submission       WorkDeclSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewerId       Int
  reviewer         User               @relation(fields: [reviewerId], references: [id])
  approved         Boolean
  notes            String?
  correctionFields String[]
  reviewedAt       DateTime
  createdAt        DateTime           @default(now())
}

// ══════════════════════════════════════════════════════════════════
// MÓDULO 1 — CRM BENEFICIÁRIOS
// ══════════════════════════════════════════════════════════════════

model Beneficiary {
  id              String            @id @default(cuid())
  code            String            @unique
  fullName        String
  type            BeneficiaryType
  category        String?
  gender          Gender?
  birthDate       DateTime?
  nationality     String?
  nif             String?
  email           String?
  phone           String?
  mobile          String?
  address         String?
  city            String?
  province        AngolaProvince?
  country         String            @default("Angola")
  status          BeneficiaryStatus @default(ACTIVE)
  source          String?
  tags            String[]
  segment         String?
  assignedToId    Int?
  totalBenefits   Float             @default(0)
  currency        String            @default("AOA")
  notes           String?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  satisfactionAvg Float             @default(0)
  createdById     Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  createdBy    User                     @relation("BeneficiaryCreator", fields: [createdById], references: [id])
  assignedTo   User?                    @relation("BeneficiaryOwner", fields: [assignedToId], references: [id])
  interactions BeneficiaryInteraction[]
  documents    BeneficiaryDocument[]
  needs        BeneficiaryNeed[]

  @@index([type])
  @@index([status])
  @@index([province])
  @@index([assignedToId])
  @@index([nextFollowUpAt])
  @@index([createdById])
  @@index([deletedAt])
}

model BeneficiaryInteraction {
  id             String          @id @default(cuid())
  beneficiaryId  String
  userId         Int
  type           InteractionType
  channel        String?
  subject        String
  description    String
  date           DateTime        @default(now())
  durationMin    Int?
  outcome        String?
  nextAction     String?
  nextActionDate DateTime?
  satisfaction   Int?
  attachments    String[]
  isPrivate      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])
  user        User        @relation("InteractionUser", fields: [userId], references: [id])

  @@index([beneficiaryId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
}

model BeneficiaryDocument {
  id            String    @id @default(cuid())
  beneficiaryId String
  name          String
  type          String
  fileUrl       String
  fileSize      Int?
  expiresAt     DateTime?
  isVerified    Boolean   @default(false)
  uploadedById  Int
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])
  uploadedBy  User        @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([beneficiaryId])
  @@index([expiresAt])
  @@index([deletedAt])
}

model BeneficiaryNeed {
  id            String       @id @default(cuid())
  beneficiaryId String
  category      String
  description   String
  priority      NeedPriority @default(MEDIUM)
  status        NeedStatus   @default(OPEN)
  resolvedAt    DateTime?
  resolvedById  Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id])

  @@index([beneficiaryId])
  @@index([status])
  @@index([priority])
}

enum BeneficiaryType {
  INDIVIDUAL
  FAMILY
  INSTITUTION
  COMMUNITY
  GROUP
}

enum BeneficiaryStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  FORMER
  BLOCKED
}

enum AngolaProvince {
  BENGO
  BENGUELA
  BIE
  CABINDA
  CUANDO_CUBANGO
  CUANZA_NORTE
  CUANZA_SUL
  CUNENE
  HUAMBO
  HUILA
  LUANDA
  LUNDA_NORTE
  LUNDA_SUL
  MALANJE
  MOXICO
  NAMIBE
  UIGE
  ZAIRE
}

enum InteractionType {
  EMAIL
  CALL
  MEETING
  VISIT
  EVENT
  NOTE
  TASK
}

enum NeedPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NeedStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ══════════════════════════════════════════════════════════════════
// MÓDULO 2 — CRM PARCEIROS
// ══════════════════════════════════════════════════════════════════

model Partner {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  legalName       String?
  type            PartnerType
  tier            PartnerTier   @default(STANDARD)
  contactName     String?
  contactTitle    String?
  email           String?
  phone           String?
  mobile          String?
  website         String?
  linkedin        String?
  nif             String?
  address         String?
  city            String?
  province        String?
  country         String        @default("Angola")
  status          PartnerStatus @default(ACTIVE)
  contractStart   DateTime?
  contractEnd     DateTime?
  contractUrl     String?
  annualValue     Float?
  currency        String        @default("AOA")
  revenueSharing  Float?
  services        String[]
  tags            String[]
  kpis            String?
  rating          Float?
  assignedToId    Int?
  notes           String?
  lastContactAt   DateTime?
  nextReviewAt    DateTime?
  satisfactionAvg Float         @default(0)
  createdById     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  createdBy    User                 @relation("PartnerCreator", fields: [createdById], references: [id])
  assignedTo   User?                @relation("PartnerOwner", fields: [assignedToId], references: [id])
  interactions PartnerInteraction[]
  milestones   PartnerMilestone[]

  @@index([type])
  @@index([tier])
  @@index([status])
  @@index([assignedToId])
  @@index([contractEnd])
  @@index([nextReviewAt])
  @@index([deletedAt])
}

model PartnerInteraction {
  id           String                 @id @default(cuid())
  partnerId    String
  userId       Int
  type         PartnerInteractionType
  channel      String?
  subject      String
  description  String
  date         DateTime               @default(now())
  durationMin  Int?
  outcome      String?
  nextAction   String?
  nextDate     DateTime?
  satisfaction Int?
  attachments  String[]
  isPrivate    Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id])
  user    User    @relation("PartnerInteractionUser", fields: [userId], references: [id])

  @@index([partnerId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
}

model PartnerMilestone {
  id          String          @id @default(cuid())
  partnerId   String
  title       String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  status      MilestoneStatus @default(PENDING)
  value       Float?
  currency    String          @default("AOA")
  priority    String          @default("MEDIUM")
  notes       String?
  createdById Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  partner   Partner @relation(fields: [partnerId], references: [id])
  createdBy User    @relation("MilestoneCreator", fields: [createdById], references: [id])

  @@index([partnerId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

enum PartnerType {
  TECHNOLOGY
  CONTENT
  TRAINING
  FUNDING
  INSTITUTIONAL
  COMMERCIAL
  MEDIA
  GOVERNMENT
  OTHER
}

enum PartnerTier {
  PLATINUM
  GOLD
  SILVER
  STANDARD
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
  NEGOTIATION
  SUSPENDED
  FORMER
}

enum PartnerInteractionType {
  EMAIL
  CALL
  MEETING
  VISIT
  EVENT
  NOTE
  REVIEW
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

// ══════════════════════════════════════════════════════════════════
// MÓDULO 3 — CRM FINANCIADORES
// ══════════════════════════════════════════════════════════════════

model Funder {
  id                String       @id @default(cuid())
  code              String       @unique
  name              String
  legalName         String?
  type              FunderType
  category          String?
  contactName       String?
  contactTitle      String?
  email             String?
  phone             String?
  mobile            String?
  website           String?
  country           String?
  region            String?
  nif               String?
  status            FunderStatus @default(ACTIVE)
  relationshipStart DateTime?
  totalCommitted    Float        @default(0)
  totalReceived     Float        @default(0)
  totalPending      Float        @default(0)
  currency          String       @default("AOA")
  focusAreas        String[]
  tags              String[]
  reportingReqs     String?
  assignedToId      Int?
  notes             String?
  lastContactAt     DateTime?
  nextReportDue     DateTime?
  satisfactionAvg   Float        @default(0)
  createdById       Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  createdBy    User                @relation("FunderCreator", fields: [createdById], references: [id])
  assignedTo   User?               @relation("FunderOwner", fields: [assignedToId], references: [id])
  grants       FundingGrant[]
  interactions FunderInteraction[]
  reports      FunderReport[]

  @@index([type])
  @@index([status])
  @@index([assignedToId])
  @@index([nextReportDue])
  @@index([deletedAt])
}

model FundingGrant {
  id             String      @id @default(cuid())
  funderId       String
  code           String      @unique
  title          String
  description    String?
  amount         Float
  disbursed      Float       @default(0)
  currency       String      @default("AOA")
  exchangeRate   Float?
  startDate      DateTime
  endDate        DateTime?
  status         GrantStatus @default(ACTIVE)
  objectives     String[]
  conditions     String?
  reportingCycle String      @default("quarterly")
  nextReportDue  DateTime?
  programIds     String[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  funder        Funder              @relation(fields: [funderId], references: [id])
  disbursements GrantDisbursement[]
  reports       FunderReport[]
  interactions  FunderInteraction[]

  @@index([funderId])
  @@index([status])
  @@index([nextReportDue])
  @@index([deletedAt])
}

model GrantDisbursement {
  id          String    @id @default(cuid())
  grantId     String
  amount      Float
  currency    String    @default("AOA")
  receivedAt  DateTime
  reference   String?
  bankRef     String?
  notes       String?
  createdById Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  grant     FundingGrant @relation(fields: [grantId], references: [id])
  createdBy User         @relation("DisbursementCreator", fields: [createdById], references: [id])

  @@index([grantId])
  @@index([receivedAt])
  @@index([deletedAt])
}

model FunderInteraction {
  id           String                @id @default(cuid())
  funderId     String
  userId       Int
  grantId      String?
  type         FunderInteractionType
  subject      String
  description  String
  date         DateTime              @default(now())
  durationMin  Int?
  outcome      String?
  nextAction   String?
  nextDate     DateTime?
  satisfaction Int?
  attachments  String[]
  isPrivate    Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  funder Funder        @relation(fields: [funderId], references: [id])
  user   User          @relation("FunderInteractionUser", fields: [userId], references: [id])
  grant  FundingGrant? @relation(fields: [grantId], references: [id])

  @@index([funderId])
  @@index([grantId])
  @@index([date])
  @@index([deletedAt])
}

model FunderReport {
  id          String       @id @default(cuid())
  funderId    String
  grantId     String?
  title       String
  period      String
  dueDate     DateTime
  submittedAt DateTime?
  status      ReportStatus @default(PENDING)
  fileUrl     String?
  feedback    String?
  notes       String?
  createdById Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  funder    Funder        @relation(fields: [funderId], references: [id])
  grant     FundingGrant? @relation(fields: [grantId], references: [id])
  createdBy User          @relation("ReportCreator", fields: [createdById], references: [id])

  @@index([funderId])
  @@index([grantId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

enum FunderType {
  GOVERNMENT
  BILATERAL
  MULTILATERAL
  NGO
  PRIVATE_FOUNDATION
  CORPORATE
  OTHER
}

enum FunderStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  FORMER
  SUSPENDED
}

enum GrantStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
  CANCELLED
  CLOSED
}

enum FunderInteractionType {
  EMAIL
  CALL
  MEETING
  VISIT
  EVENT
  NOTE
  REVIEW
}

enum ReportStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  OVERDUE
}


