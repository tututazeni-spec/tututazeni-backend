generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// CORE / USERS & ORG
//////////////////////////
model User {
  id                      Int                     @id @default(autoincrement())
  fullName                String                  @db.Text
  password                String
  email                   String                  @unique
  roleId                  Int?
  role                    Role?                   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  active                  Boolean                 @default(true)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  unitId                  Int?
  unit                    Unit?                   @relation(fields: [unitId], references: [id])
  profile                 Profile?
  enrollments             Enrollment[]
  questions               Questions[]
  answers                 Answers[]
  performance             PerformanceReview[]
  points                  UserPoints?
  microLearningDispatches MicroLearningDispatch[]
  position                Position?               @relation("PositionUsers", fields: [positionId], references: [id])
  positionId              Int?
  onboardingPlans         OnboardingPlan[]
  reportLogs              ReportLog[]
  badgeAwards             BadgeAward[]
  courseFeedbacks         CourseFeedback[]
  notificationLogs        NotificationLog[]
  auditLogs               AuditLog[]
  successionPlans         SuccessionPlan[]
  assessmentAttempts      AssessmentAttempt[]
  userCompetencies        UserCompetency[]
  developmentPlans        DevelopmentPlan[]
  leadershipPrograms      LeadershipParticipant[]
  articles                KnowledgeArticle[]
  interactions            KnowledgeInteraction[]
  tags                    KnowledgeTag[]
  processStandards        ProcessStandard[]
  processSteps            ProcessStep[]
  trainings               Training[]
  trainingParticipants    TrainingParticipant[]
  careers                 UserCareer[]
  departmentId            Int?
  department              Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  historyRecords          HistoryRecord[]
  mobileSessions          MobileSession[]
  mobileSyncLogs          MobileSyncLog[]
  executiveReports        ExecutiveReport[]
  aiSessions              AiTutorSession[]
  liveAttendances         LiveAttendance[]
  liveMessages            LiveChatMessage[]
  postClassResponses      PostClassResponse[]
  instructorProfile       InstructorProfile?
  instructorReviews       InstructorReview[]
  events                  Event[]
  eventParticipants       EventParticipant[]
  payslips                Payslip[]
  workDeclarations        WorkDeclaration[]
  initiatedInstances      ProcessInstance[]  @relation("InitiatedInstances")
  targetInstances         ProcessInstance[]  @relation("TargetInstances")
  completedSteps          StepProgress[]     @relation("StepCompletedBy")
  companyDocuments        CompanyDocument[]
  documentDownloads       DocumentDownload[]
  surveyResponses         SurveyResponse[]
  evaluationsGiven        PerformanceEvaluation[] @relation("EvaluatorRelation")
  evaluationsReceived     PerformanceEvaluation[] @relation("EvaluatedRelation")
  evaluationRequestsGiven    EvaluationRequest[] @relation("RequestEvaluator")
  evaluationRequestsReceived EvaluationRequest[] @relation("RequestEvaluated")
  userAttendances         UserAttendance[]
  competencyMaps          CompetencyMap[] @relation("UserCompetencyMaps")
  assessedCompetencyMaps  CompetencyMap[] @relation("AssessedCompetencyMaps")
  userCareerPlans         UserCareerPlan[] @relation("UserCareerPlans")
  mentoredPlans           UserCareerPlan[] @relation("MentoredPlans")
  avatarSessions          AvatarSession[]

}

model Answers {
  id         Int       @id @default(autoincrement())
  body       String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     Int
  questionId Int
  user       User      @relation(fields: [userId], references: [id])
  question   Questions @relation(fields: [questionId], references: [id])
}

model Questions {
  id        Int       @id @default(autoincrement())
  title     String    @db.Text
  body      String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  answers   Answers[]
}

model Profile {
  id     Int    @id @default(autoincrement())
  bio    String @db.Text
  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Unit {
  id                      Int                      @id @default(autoincrement())
  name                    String
  tipo                    String
  province                String?
  users                   User[]
  departmentId            Int?
  department              Department?              @relation("UnitDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  learningPathAssignments LearningPathAssignment[] @relation("UnitLearningPathAssignments")
  operationalMetrics      OperationalMetric[]
}

model Department {
  id                 Int                 @id @default(autoincrement())
  name               String
  createdAt          DateTime            @default(now())
  units              Unit[]              @relation("UnitDepartment")
  users              User[]
  dashboardSnapshots DashboardSnapshot[]
  executiveReports   ExecutiveReport[]
  companyDocuments   CompanyDocument[]

  @@index([name])
}

model DashboardSnapshot {
  id                    Int         @id @default(autoincrement())
  departmentId          Int?
  totalUsers            Int
  totalCoursesCompleted Int
  averageScore          Float
  activePlans           Int
  generatedAt           DateTime    @default(now())
  department            Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([departmentId])
}

model Post {
  id         Int        @id @default(autoincrement())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  title      String     @db.Text
  published  Boolean    @default(false)
  categories Category[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model GlobalSearchIndex {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  title       String
  description String?  @db.Text
  route       String?
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([title])
}

model ApiIntegrationLog {
  id            Int      @id @default(autoincrement())
  integrationId Int
  status        String
  statusCode    Int?
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([integrationId])
}

enum UserRole {
  COLABORADOR
  LIDER
  RH
  ADMIN
}

//////////////////////////
// USER CAREER PLANS
//////////////////////////
model UserCareerPlan {
  id             Int           @id @default(autoincrement())
  userId         Int
  mentorId       Int?
  title          String
  description    String?       @db.Text
  targetPosition String?
  targetDate     DateTime?
  status         String        @default("DRAFT")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation("UserCareerPlans", fields: [userId], references: [id], onDelete: Cascade)
  mentor         User?         @relation("MentoredPlans", fields: [mentorId], references: [id], onDelete: SetNull)
  goals          CareerGoal[]

  @@index([userId])
  @@index([status])
}

model CareerGoal {
  id           Int            @id @default(autoincrement())
  careerPlanId Int
  title        String
  description  String?        @db.Text
  category     String?
  status       String         @default("PENDING")
  progress     Int            @default(0)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  careerPlan   UserCareerPlan @relation(fields: [careerPlanId], references: [id], onDelete: Cascade)

  @@index([careerPlanId])
}

//////////////////////////
// PERFORMANCE EVALUATION
//////////////////////////

model PerformanceEvaluation {
  id             Int      @id @default(autoincrement())
  evaluatorId    Int
  evaluatedId    Int
  type           EvalType
  period         String
  criteria       Json
  generalComment String?  @db.Text
  overallScore   Float    @default(0)
  createdAt      DateTime @default(now())
  evaluator      User     @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])
  evaluated      User     @relation("EvaluatedRelation", fields: [evaluatedId], references: [id])

  @@index([evaluatedId])
  @@index([evaluatorId])
  @@index([period])
}

model EvaluationRequest {
  id          Int      @id @default(autoincrement())
  evaluatorId Int
  evaluatedId Int
  status      String   @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  evaluator   User     @relation("RequestEvaluator", fields: [evaluatorId], references: [id])
  evaluated   User     @relation("RequestEvaluated", fields: [evaluatedId], references: [id])

  @@index([evaluatorId])
  @@index([evaluatedId])
}

enum EvalType {
  SELF
  MANAGER
  PEER
  SUBORDINATE
}

//////////////////////////
// ENGAGEMENT
//////////////////////////

model EngagementSurvey {
  id          Int              @id @default(autoincrement())
  title       String
  description String?          @db.Text
  status      String           @default("ACTIVE")
  endDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   SurveyQuestion[]
  responses   SurveyResponse[]

  @@index([status])
}

model SurveyQuestion {
  id        Int              @id @default(autoincrement())
  surveyId  Int
  text      String           @db.Text
  type      String
  order     Int
  survey    EngagementSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers   SurveyAnswer[]

  @@index([surveyId])
}

model SurveyResponse {
  id        Int              @id @default(autoincrement())
  surveyId  Int
  userId    Int
  score     Float?
  createdAt DateTime         @default(now())
  survey    EngagementSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   SurveyAnswer[]

  @@index([surveyId])
  @@index([userId])
}

model SurveyAnswer {
  id         Int            @id @default(autoincrement())
  responseId Int
  questionId Int
  value      Int
  comment    String?        @db.Text
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
}

//////////////////////////
// LEARNING
//////////////////////////
model Course {
  id            Int                  @id @default(autoincrement())
  title         String               @db.Text
  description   String?              @db.Text
  category      String?
  workloadHours Int?
  mandatory     Boolean              @default(false)
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  modules       Module[]
  enrollments   Enrollment[]
  evaluations   Evaluation[]
  competencies  CourseCompetency[]
  learningPaths LearningPathCourse[]
  analytics     CourseAnalytics[]
  feedbacks     CourseFeedback[]
  assessments   Assessment[]
  aiSessions    AiTutorSession[]
  liveClasses   LiveClass[]
}

model LearningPath {
  id          Int                      @id @default(autoincrement())
  title       String                   @db.Text
  description String?                  @db.Text
  mandatory   Boolean                  @default(false)
  createdAt   DateTime                 @default(now())
  courses     LearningPathCourse[]
  assignments LearningPathAssignment[]
}

model LearningPathCourse {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  courseId       Int
  seq            Int
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
}

model LearningPathAssignment {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  unitId         Int?
  role           UserRole?
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  unit           Unit?        @relation("UnitLearningPathAssignments", fields: [unitId], references: [id])
}

model Module {
  id        Int      @id @default(autoincrement())
  courseId  Int
  title     String
  seq       Int
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id          Int               @id @default(autoincrement())
  moduleId    Int
  title       String
  contentType LessonContentType @default(VIDEO)
  videoUrl    String?           @db.Text
  pdfUrl      String?           @db.Text
  seq         Int
  createdAt   DateTime          @default(now())
  module      Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses  LessonProgress[]
}

model Enrollment {
  id          Int                 @id @default(autoincrement())
  userId      Int
  courseId    Int
  status      EnrollmentStatus    @default(EM_ANDAMENTO)
  enrolledAt  DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses  LessonProgress[]
  attempts    EvaluationAttempt[] @relation("EnrollmentAttempts")
  certificate Certificate?
  aiSessions  AiTutorSession[]

  @@index([userId])
  @@index([courseId])
}

model Assessment {
  id                 Int                  @id @default(autoincrement())
  courseId           Int
  title              String
  passScore          Float                @default(70)
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions          AssessmentQuestion[]
  assessmentAttempts AssessmentAttempt[]
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  question     String     @db.Text
  options      Json
  correctIndex Int
  weight       Float      @default(1)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentAttempt {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  userId       Int
  score        Float
  passed       Boolean
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([userId])
}

model LessonProgress {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  lessonId     Int
  completed    Boolean    @default(false)
  completedAt  DateTime?
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

model Evaluation {
  id                 Int                  @id @default(autoincrement())
  courseId           Int
  title              String
  createdAt          DateTime             @default(now())
  question           String               @db.Text
  options            Json
  correctOptionIndex Int
  employeeId         Int
  score              Float
  feedback           String               @db.Text
  evaluatedAt        DateTime
  employee           Employee             @relation(fields: [employeeId], references: [id])
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts           EvaluationAttempt[]
  questions          EvaluationQuestion[]

  @@index([courseId])
}

model EvaluationQuestion {
  id                       Int                       @id @default(autoincrement())
  evaluationId             Int
  question                 String                    @db.Text
  options                  Json
  correctIndex             Int
  evaluation               Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluationAttemptAnswers EvaluationAttemptAnswer[]

  @@index([evaluationId])
}

model EvaluationAttempt {
  id             Int                       @id @default(autoincrement())
  enrollmentId   Int
  validationCode String
  scorePercent   Float?
  passed         Boolean?
  attemptedAt    DateTime                  @default(now())
  startedAt      DateTime                  @default(now())
  finishedAt     DateTime?
  evaluationId   Int
  enrollment     Enrollment                @relation("EnrollmentAttempts", fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluation     Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  answers        EvaluationAttemptAnswer[]

  @@index([evaluationId])
  @@index([enrollmentId])
}

model EvaluationAttemptAnswer {
  id            Int                @id @default(autoincrement())
  attemptId     Int
  questionId    Int
  selectedIndex Int
  isCorrect     Boolean
  createdAt     DateTime           @default(now())
  attempt       EvaluationAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      EvaluationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

model Certificate {
  id                Int                @id @default(autoincrement())
  type              CertificateType
  enrollmentId      Int?               @unique
  programId         Int?
  developmentPlanId Int?
  issuedAt          DateTime           @default(now())
  validationCode    String             @unique
  fileUrl           String?            @db.Text
  revoked           Boolean            @default(false)
  enrollment        Enrollment?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  program           LeadershipProgram? @relation(fields: [programId], references: [id])
  developmentPlan   DevelopmentPlan?   @relation(fields: [developmentPlanId], references: [id])
}

model MicroLearning {
  id        Int                     @id @default(autoincrement())
  title     String
  content   String                  @db.Text
  createdAt DateTime                @default(now())
  dispatch  MicroLearningDispatch[]
  active    Boolean                 @default(true)
}

model MicroLearningDispatch {
  id              Int           @id @default(autoincrement())
  microLearningId Int
  userId          Int
  viewed          Boolean       @default(false)
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarScript {
  id        Int      @id @default(autoincrement())
  title     String
  script    String   @db.Text
  version   Int      @default(1)
  videoUrl  String?  @db.Text
  createdAt DateTime @default(now())
}

model ContentAsset {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  type        String
  url         String   @db.Text
  version     Int      @default(1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Training {
  id           Int               @id @default(autoincrement())
  title        String
  description  String?           @db.Text
  startDate    DateTime
  endDate      DateTime
  location     String?
  instructorId Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   User              @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  sessions     TrainingSession[]
}

model TrainingSession {
  id           Int                   @id @default(autoincrement())
  trainingId   Int
  sessionDate  DateTime
  duration     Int
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  training     Training              @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  participants TrainingParticipant[]
}

model TrainingParticipant {
  id        Int             @id @default(autoincrement())
  sessionId Int
  userId    Int
  status    String          @default("registered")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LiveClass {
  id             Int                  @id @default(autoincrement())
  courseId       Int
  zoomMeetingId  String?              @db.Text
  topic          String               @db.Text
  scheduledAt    DateTime
  duration       Int
  recordingUrl   String?              @db.Text
  createdAt      DateTime             @default(now())
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances    LiveAttendance[]
  messages       LiveChatMessage[]
  postEvaluation PostClassEvaluation?

  @@index([courseId])
}

model LiveAttendance {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  joinedAt    DateTime
  leftAt      DateTime?
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, userId])
}

model LiveChatMessage {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  message     String    @db.Text
  createdAt   DateTime  @default(now())
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

model PostClassEvaluation {
  id           Int                 @id @default(autoincrement())
  liveClassId  Int                 @unique
  averageScore Float               @default(0)
  liveClass    LiveClass           @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  responses    PostClassResponse[]
}

model PostClassResponse {
  id           Int                 @id @default(autoincrement())
  evaluationId Int
  userId       Int
  rating       Int
  feedback     String?             @db.Text
  createdAt    DateTime            @default(now())
  evaluation   PostClassEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, userId])
}

model AvatarScenario {
  id           Int             @id @default(autoincrement())
  title        String
  description  String?         @db.Text
  difficulty   Int             @default(1)
  competencyId Int?
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  competency   Competency?     @relation(fields: [competencyId], references: [id], onDelete: SetNull)
  sessions     AvatarSession[]

  @@index([competencyId])
}

model AvatarSession {
  id          Int            @id @default(autoincrement())
  userId      Int
  scenarioId  Int
  status      String         @default("IN_PROGRESS")
  score       Float?
  feedback    String?        @db.Text
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario    AvatarScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
}

enum LessonContentType {
  VIDEO
  AVATAR
  PDF
  QUIZ
}

enum CertificateType {
  COURSE
  LEADERSHIP
  DEVELOPMENT
}

enum EnrollmentStatus {
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

//////////////////////////
// HR
//////////////////////////

model CompetencyMap {
  id            Int        @id @default(autoincrement())
  userId        Int
  competencyId  Int
  currentLevel  Int
  targetLevel   Int
  assessedById  Int?
  notes         String?    @db.Text
  assessedAt    DateTime   @default(now())
  user          User       @relation("UserCompetencyMaps", fields: [userId], references: [id], onDelete: Cascade)
  competency    Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  assessedBy    User?      @relation("AssessedCompetencyMaps", fields: [assessedById], references: [id], onDelete: SetNull)

  @@unique([userId, competencyId])
  @@index([userId])
  @@index([competencyId])
}

model UserAttendance {
  id          Int       @id @default(autoincrement())
  userId      Int
  date        DateTime
  clockIn     String?
  clockOut    String?
  workMinutes Int?
  status      String    @default("PRESENT")
  notes       String?   @db.Text
  justification String? @db.Text
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Position {
  id              Int              @id @default(autoincrement())
  name            String
  level           String?
  department      String?
  users           User[]           @relation("PositionUsers")
  successionPlans SuccessionPlan[]
}

model PerformanceReview {
  id        Int      @id @default(autoincrement())
  userId    Int
  score     Float
  comment   String?  @db.Text
  period    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SuccessionPlan {
  id          Int      @id @default(autoincrement())
  positionId  Int
  candidateId Int
  readiness   String   @db.Text
  createdAt   DateTime @default(now())
  position    Position @relation(fields: [positionId], references: [id])
  candidate   User     @relation(fields: [candidateId], references: [id])
}

model OnboardingPlan {
  id        Int      @id @default(autoincrement())
  userId    Int
  tasks     Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Competency {
  id               Int                  @id @default(autoincrement())
  name             String               @unique
  description      String?              @db.Text
  createdAt        DateTime             @default(now())
  courses          CourseCompetency[]
  userCompetencies UserCompetency[]
  positions        PositionCompetency[]
  competencyMaps   CompetencyMap[]
  avatarScenarios  AvatarScenario[]
}

model CourseCompetency {
  id           Int        @id @default(autoincrement())
  courseId     Int
  competencyId Int
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
}

model UserCompetency {
  id           Int        @id @default(autoincrement())
  userId       Int
  competencyId Int
  level        Int
  evaluatedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([userId, competencyId])
}

model DevelopmentPlan {
  id           Int           @id @default(autoincrement())
  userId       Int
  goal         String
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificates Certificate[]
}

model LeadershipProgram {
  id           Int                     @id @default(autoincrement())
  name         String
  description  String?                 @db.Text
  active       Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  participants LeadershipParticipant[]
  certificates Certificate[]
}

model LeadershipParticipant {
  id         Int               @id @default(autoincrement())
  userId     Int
  programId  Int
  status     String            @default("ENROLLED")
  progress   Int               @default(0)
  enrolledAt DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  program    LeadershipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

model KnowledgeArticle {
  id           Int                    @id @default(autoincrement())
  title        String
  description  String?                @db.Text
  content      String
  authorId     Int
  categoryId   Int?
  tags         KnowledgeTag[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  author       User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category     KnowledgeCategory?     @relation(fields: [categoryId], references: [id])
  interactions KnowledgeInteraction[]
}

model KnowledgeTag {
  id        Int              @id @default(autoincrement())
  name      String
  articleId Int
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id])
  userId    Int?
}

model KnowledgeCategory {
  id       Int                @id @default(autoincrement())
  name     String
  articles KnowledgeArticle[]
}

model KnowledgeInteraction {
  id        Int              @id @default(autoincrement())
  userId    Int
  articleId Int
  action    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ProcessStandard {
  id          Int           @id @default(autoincrement())
  title       String
  description String?       @db.Text
  ownerId     Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  steps       ProcessStep[]
  instances   ProcessInstance[]
}

model ProcessStep {
  id            Int             @id @default(autoincrement())
  processId     Int
  title         String
  description   String?         @db.Text
  responsibleId Int
  order         Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  process       ProcessStandard @relation(fields: [processId], references: [id], onDelete: Cascade)
  responsible   User            @relation(fields: [responsibleId], references: [id], onDelete: Cascade)
  stepProgress  StepProgress[]
}

model CareerPosition {
  id           Int                  @id @default(autoincrement())
  title        String
  description  String               @db.Text
  level        String
  createdAt    DateTime             @default(now())
  competencies PositionCompetency[]
  users        UserCareer[]

  @@index([level])
}

model PositionCompetency {
  id            Int            @id @default(autoincrement())
  positionId    Int
  competencyId  Int
  requiredLevel Int
  position      CareerPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  competency    Competency     @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([positionId, competencyId])
  @@index([positionId])
  @@index([competencyId])
}

model UserCareer {
  id         Int            @id @default(autoincrement())
  userId     Int
  positionId Int
  startedAt  DateTime       @default(now())
  endedAt    DateTime?
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  position   CareerPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([positionId])
}

model HistoryRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String
  entityType  String
  entityId    Int?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
}

model Employee {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  role        String
  joinedAt    DateTime
  careerPlans CareerPlan[]
  feedbacks   Feedback360[]
  contracts   Contract[]
  evaluations Evaluation[]
  attendances Attendance[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Contract {
  id         Int      @id @default(autoincrement())
  employeeId Int
  startDate  DateTime
  endDate    DateTime
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  date        DateTime
  hoursWorked Float
  status      String
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model CareerPlan {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  title       String
  description String   @db.Text
  startDate   DateTime
  endDate     DateTime
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
}

model Feedback360 {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  evaluatorName String
  evaluatorRole String
  score         Float
  comments      String   @db.Text
  evaluatedAt   DateTime
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id])
}

 model Payslip {
   id              Int       @id @default(autoincrement())
   userId          Int
   period          String
   status          String    @default("DRAFT")
   baseSalary      Float
   bonuses         Float?
   allowances      Float?
   overtime        Float?
   incomeTax       Float?
   socialSecurity  Float?
   otherDeductions Float?
   grossSalary     Float
   totalDeductions Float
   netSalary       Float
   notes           String?   @db.Text
   issuedAt        DateTime?
   acknowledgedAt  DateTime?
   createdAt       DateTime  @default(now())
   user            User      @relation(fields: [userId], references: [id])
   @@unique([userId, period])
 }

  model ProcessInstance {
    id            Int           @id @default(autoincrement())
    processId     Int
    initiatedById Int
    targetUserId  Int
    status        String        @default("IN_PROGRESS")
    createdAt     DateTime      @default(now())
    process       ProcessStandard @relation(fields: [processId], references: [id])
    initiatedBy   User          @relation("InitiatedInstances", fields: [initiatedById], references: [id])
    targetUser    User          @relation("TargetInstances", fields: [targetUserId], references: [id])
    stepProgress  StepProgress[]
  }
 
  model StepProgress {
    id            Int             @id @default(autoincrement())
    instanceId    Int
    stepId        Int
    status        String          @default("PENDING")
    completedById Int?
    completedAt   DateTime?
    notes         String?         @db.Text
    instance      ProcessInstance @relation(fields: [instanceId], references: [id])
    step          ProcessStep     @relation(fields: [stepId], references: [id])
    completedBy   User?           @relation("StepCompletedBy", fields: [completedById], references: [id]) 
  @@unique([instanceId, stepId])
}

  model WorkDeclaration {
   id              Int       @id @default(autoincrement())
   userId          Int
   type            String
   status          String    @default("PENDING")
   purpose         String?   @db.Text
   addressedTo     String?
   content         String?   @db.Text
   referenceNumber String?   @unique
   generatedAt     DateTime?
   issuedAt        DateTime?
   createdAt       DateTime  @default(now())
   user            User      @relation(fields: [userId], references: [id])
 }

 //////////////////////////
// DOCUMENT REPOSITORY
//////////////////////////

model CompanyDocument {
  id            Int              @id @default(autoincrement())
  title         String
  description   String?          @db.Text
  category      DocCategory
  access        DocAccess
  fileUrl       String           @db.Text
  fileType      String
  fileSize      Int?
  version       String?
  tags          String[]
  downloadCount Int              @default(0)
  active        Boolean          @default(true)
  createdById   Int
  departmentId  Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     User             @relation(fields: [createdById], references: [id])
  department    Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  downloads     DocumentDownload[]

  @@index([category])
  @@index([access])
  @@index([createdById])
  @@index([departmentId])
}

model DocumentDownload {
  id           Int             @id @default(autoincrement())
  documentId   Int
  userId       Int
  downloadedAt DateTime        @default(now())
  document     CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

enum DocCategory {
  POLITICA
  MANUAL
  PROCEDIMENTO
  FORMULARIO
  CONTRATO
  REGULAMENTO
  COMUNICADO
  OUTRO
}

enum DocAccess {
  PUBLIC
  DEPARTMENT
  RESTRICTED
}

