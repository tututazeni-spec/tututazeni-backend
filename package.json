{
  "name": "innova",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "20.x"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "prisma:check": "prisma validate",
    "migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:deploy": "prisma migrate deploy",
    "db:deploy:test": "cross-env NODE_ENV=test prisma migrate deploy",
    "db:generate": "prisma migrate dev && prisma generate",
    "db:seed": "prisma db seed",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --config eslint.config.staged.mjs --fix --cache --cache-location .eslintcache",
    "lint:check": "eslint \"src/**/*.ts\" --config eslint.config.staged.mjs --cache --cache-location .eslintcache --max-warnings=9999",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --forceExit",
    "test:coverage": "jest --coverage --forceExit --passWithNoTests",
    "test:coverage:watch": "jest --coverage --watch",
    "test:e2e": "playwright test",
    "test:unit": "jest --testPathPattern=spec --forceExit",
    "test:db": "cross-env NODE_ENV=test jest --config test/jest-database.json --forceExit --runInBand",
    "test:db:performance": "cross-env NODE_ENV=test jest --config test/jest-database.json --testPathPatterns=query-performance --forceExit --runInBand",
    "test:db:integrity": "cross-env NODE_ENV=test jest --config test/jest-database.json --testPathPatterns=data-integrity --forceExit --runInBand",
    "test:db:migrations": "cross-env NODE_ENV=test jest --config test/jest-database.json --testPathPatterns=migrations --forceExit --runInBand",
    "test:db:transactions": "cross-env NODE_ENV=test jest --config test/jest-database.json --testPathPatterns=transactions --forceExit --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest --config test/jest-integration.json --forceExit --runInBand",
    "test:integration:auth": "cross-env NODE_ENV=test jest --config test/jest-integration.json --testPathPatterns=auth --forceExit --runInBand",
    "test:integration:courses": "cross-env NODE_ENV=test jest --config test/jest-integration.json --testPathPatterns=courses --forceExit --runInBand",
    "test:integration:enrollment": "cross-env NODE_ENV=test jest --config test/jest-integration.json --testPathPatterns=enrollment --forceExit --runInBand",
    "test:integration:users": "cross-env NODE_ENV=test jest --config test/jest-integration.json --testPathPatterns=users --forceExit --runInBand",
    "test:security": "npm audit && npx owasp-dependency-check",
    "test:smoke": "cross-env NODE_ENV=test npx artillery run --config load-tests/phases/smoke.yml load-tests/artillery.yml",
    "test:load": "cross-env NODE_ENV=test npx artillery run --config load-tests/phases/load.yml load-tests/artillery.yml --output load-tests/reports/load-report.json",
    "test:load:innova": "cross-env NODE_ENV=test npx artillery run --config load-tests/phases/load.yml load-tests/artillery.yml --output load-tests/reports/load-report.json",
    "test:load:peak": "npx artillery run test/load/artillery-peak.yml",
    "test:load:smoke": "npx artillery run test/load/artillery-smoke.yml",
    "test:stress": "cross-env NODE_ENV=test npx artillery run --config load-tests/phases/stress.yml load-tests/artillery.yml --output load-tests/reports/stress-report.json",
    "test:spike": "cross-env NODE_ENV=test npx artillery run --config load-tests/phases/spike.yml load-tests/artillery.yml --output load-tests/reports/spike-report.json",
    "test:report": "npx artillery report load-tests/reports/load-report.json --output load-tests/reports/load-report.html",
    "test:report:stress": "npx artillery report load-tests/reports/stress-report.json --output load-tests/reports/stress-report.html",
    "test:report:spike": "npx artillery report load-tests/reports/spike-report.json --output load-tests/reports/spike-report.html",
    "seed:loadtest": "ts-node --transpile-only prisma/seed-load-test.ts",
    "start:test": "cross-env UV_THREADPOOL_SIZE=16 NODE_ENV=test nest start --watch",
    "hash-password": "ts-node -P tsconfig.json scripts/hashPassword.ts",
    "check-user": "ts-node -P tsconfig.json scripts/checkUser.ts",
    "fix-role": "ts-node -P tsconfig.json scripts/fixUserRole.ts",
    "change-role": "ts-node -P tsconfig.json scripts/changeRole.ts",
    "render:build": "npm install --include=dev && npm run db:deploy && npm run build",
    "render:start": "npm start",
    "test:api": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run . -r --env local",
    "test:api:auth": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run auth/ --env local",
    "test:api:courses": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run courses/ --env local",
    "test:api:enrollment": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run enrollment/ --env local",
    "test:api:users": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run users/ -r --env local",
    "test:api:pdi": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run pdi/ --env local",
    "test:api:report": "cd bruno && node ../node_modules/@usebruno/cli/bin/bru.js run . -r --env local --reporter-json reports/results.json",
    "sonar": "sonar-scanner",
    "sonar:local": "sonar-scanner -Dsonar.host.url=http://localhost:9000",
    "prepare": "husky",
    "build:loadtest": "nest build",
    "start:loadtest": "cross-env UV_THREADPOOL_SIZE=16 NODE_ENV=test node dist/main.js",
    "test:wait-server": "node -e \"const h=require('http');let t=0;const i=setInterval(()=>{h.get('http://localhost:4000',(r)=>{if(r.statusCode===200){clearInterval(i);process.exit(0)}}).on('error',()=>{if(++t>30){process.exit(1)}})},1000)\"",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report test/e2e/reports",
    "db:verify-replica": "node scripts/verify-replica.cjs"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix --max-warnings=9999 --cache --cache-location .eslintcache-staged --config eslint.config.staged.mjs",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.5.0",
    "@prisma/extension-read-replicas": "^0.5.0",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.0.2",
    "typeorm": "^0.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.60.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@usebruno/cli": "^3.4.0",
    "artillery": "^2.0.21",
    "artillery-plugin-expect": "^2.26.0",
    "artillery-plugin-metrics-by-endpoint": "^1.26.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "sonarqube-scanner": "^4.3.6",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.dto.ts",
      "!**/*.entity.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json-summary"
    ],
    "testEnvironment": "node"
  }
}
