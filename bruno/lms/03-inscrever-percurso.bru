  token: {{accessToken}}
}

tests {
  test("Status 201", function() {
    expect(res.status).to.equal(201);
  });
  test("Tem pathId", function() {
    expect(res.body.pathId).to.equal(bru.getEnvVar("pathId"));
  });
}
