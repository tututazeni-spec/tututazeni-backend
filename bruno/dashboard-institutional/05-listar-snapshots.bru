meta {
  name: Listar Snapshots
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/dashboard-institutional/snapshots?page=1&limit=12
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Paginação", function() {
    expect(res.body).to.have.property("totalPages");
  });
}
